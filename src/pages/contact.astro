---
// contact.astro - Contact page
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Contact Jamail Hardwoods | Houston Showroom, Hours & Appointments"
  description="Contact Jamail Hardwoods in Houston for hardwood flooring consultation, installation planning, and showroom appointments. Call +1 (832) 930-5936 or book online today."
>
  <Header />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="absolute -top-20 -right-20 h-64 w-64 rounded-full bg-brand-brass/10 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-brand-oak/10 blur-3xl pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Contact Jamail Hardwoods</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">
          Speak directly with our Houston hardwood specialists about products, timelines, installation, and design direction. Whether you are renovating one room or an entire home, we can help you choose the right floor with confidence.
        </p>
        <div class="mt-5 flex flex-wrap gap-2 text-xs sm:text-sm text-brand-ink/70">
          <span class="rounded-full bg-white/80 px-3 py-1 shadow-soft">European White Oak Experts</span>
          <span class="rounded-full bg-white/80 px-3 py-1 shadow-soft">Showroom Support</span>
          <span class="rounded-full bg-white/80 px-3 py-1 shadow-soft">Installation Guidance</span>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="https://jamail-hardwoods-leads.vercel.app/booking"
             class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition"
             target="_blank" rel="nofollow noopener noreferrer">
            Book Appointment
          </a>
          <a href="tel:+18329305936"
             class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">
            Call +1 (832) 930-5936
          </a>
        </div>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="rounded-xl bg-white/85 p-3 shadow-soft">
            <p class="text-xs text-brand-ink/60">Typical Response</p>
            <p class="font-semibold">Within 1 business day</p>
          </div>
          <div class="rounded-xl bg-white/85 p-3 shadow-soft">
            <p class="text-xs text-brand-ink/60">Consultations</p>
            <p class="font-semibold">In-person or virtual</p>
          </div>
          <div class="rounded-xl bg-white/85 p-3 shadow-soft">
            <p class="text-xs text-brand-ink/60">Service Focus</p>
            <p class="font-semibold">Greater Houston homes</p>
          </div>
        </div>
      </div>
      <div class="reveal">
        <div class="rounded-3xl overflow-hidden shadow-glass">
          <img src="/images/showroom jamail hardwoods houston texas.JPEG" alt="Jamail Hardwoods Houston showroom with premium wide-plank hardwood samples"
               class="rounded-3xl shadow-soft w-full aspect-[4/3] object-cover transition duration-700 hover:scale-[1.02]" loading="lazy" decoding="async">
        </div>
      </div>
    </div>
  </section>

  <!-- Why Contact Us -->
  <section class="container mx-auto px-4 sm:px-6 py-10">
    <div class="grid md:grid-cols-3 gap-6">
      <article class="reveal rounded-2xl bg-white p-6 shadow-soft hover:shadow-glass transition">
        <h2 class="font-heading text-xl">Project Planning Support</h2>
        <p class="mt-2 text-brand-ink/80 text-sm leading-relaxed">Get help with floor selection, room flow, and matching tones to your cabinets, walls, and lighting conditions.</p>
      </article>
      <article class="reveal rounded-2xl bg-white p-6 shadow-soft hover:shadow-glass transition">
        <h2 class="font-heading text-xl">Transparent Installation Guidance</h2>
        <p class="mt-2 text-brand-ink/80 text-sm leading-relaxed">Understand prep requirements, timelines, and what to expect before your hardwood flooring installation begins.</p>
      </article>
      <article class="reveal rounded-2xl bg-white p-6 shadow-soft hover:shadow-glass transition">
        <h2 class="font-heading text-xl">Houston Showroom Experience</h2>
        <p class="mt-2 text-brand-ink/80 text-sm leading-relaxed">Compare full planks side-by-side and see how finishes look under real light before making your final choice.</p>
      </article>
    </div>
  </section>

  <!-- Contact Blocks -->
  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="grid md:grid-cols-3 gap-6">
      <!-- Address -->
      <div class="rounded-2xl bg-white p-6 shadow-soft">
        <h2 class="font-heading text-xl sm:text-2xl">Visit Our Showroom</h2>
        <p class="mt-2 text-brand-ink/80 leading-relaxed">
          See full planks, compare finishes, and get hands-on with our European White Oak collections.
        </p>
        <div class="mt-4 text-brand-ink/70">
          <p class="font-medium">2643 Colquitt St</p>
          <p>Houston, TX 77098</p>
        </div>
      </div>

      <!-- Phone / Email -->
      <div class="rounded-2xl bg-white p-6 shadow-soft">
        <h2 class="font-heading text-xl sm:text-2xl">Get in Touch</h2>
        <p class="mt-2 text-brand-ink/80 leading-relaxed">Questions about products, pricing, or timeline? We're here to help.</p>
        <div class="mt-4 space-y-2">
          <p><a href="tel:+18329305936" class="text-brand-brass hover:underline">+1 (832) 930-5936</a></p>
          <p><a href="mailto:sales@jamailfloors.com" class="text-brand-brass hover:underline">sales@jamailfloors.com</a></p>
        </div>
      </div>

      <!-- Hours -->
      <div class="rounded-2xl bg-white p-6 shadow-soft">
        <h2 class="font-heading text-xl sm:text-2xl">Showroom Hours</h2>
        <p class="mt-2 text-brand-ink/80 leading-relaxed">Visit by appointment for personalized attention and expert guidance.</p>
        <div class="mt-4 text-sm text-brand-ink/70 space-y-1">
          <p><strong>Mon-Fri:</strong> 10:00 AM - 6:00 PM</p>
          <p><strong>Saturday:</strong> 10:00 AM - 5:00 PM</p>
          <p><strong>Sunday:</strong> By appointment</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area + Map -->
  <section class="bg-brand-sand/35 py-16">
    <div class="container mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-8 items-start">
      <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
        <h2 class="font-heading text-2xl">Hardwood Flooring Help Across Greater Houston</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">
          We work with homeowners, designers, and builders throughout Houston and nearby neighborhoods. If you are searching for premium hardwood flooring in Houston with expert consultation and installation planning, our team is ready to assist.
        </p>
        <div class="mt-4 grid grid-cols-2 gap-2 text-sm text-brand-ink/75">
          <p>• River Oaks</p>
          <p>• West University</p>
          <p>• The Heights</p>
          <p>• Bellaire</p>
          <p>• Memorial</p>
          <p>• Tanglewood</p>
        </div>
      </div>
      <div class="reveal rounded-2xl overflow-hidden shadow-soft bg-white">
        <iframe
          title="Jamail Hardwoods Houston location map"
          src="https://www.google.com/maps?q=2643%20Colquitt%20St%2C%20Houston%2C%20TX%2077098&output=embed"
          class="w-full h-[340px] border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>

  <!-- Quick Help FAQ (accordion) -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <h2 class="font-heading text-2xl sm:text-3xl mb-6 text-center">Quick Answers</h2>
      <div class="mx-auto max-w-3xl space-y-3" data-accordion>
        <details class="group rounded-2xl bg-brand-sand/40 p-4 shadow-soft">
          <summary class="cursor-pointer font-medium text-brand-ink hover:text-brand-brass transition">
            Do I need an appointment to visit?
          </summary>
          <p class="mt-2 text-sm text-brand-ink/70">Appointments ensure we can give you personalized attention, but walk-ins are welcome during showroom hours.</p>
        </details>
        
        <details class="group rounded-2xl bg-brand-sand/40 p-4 shadow-soft">
          <summary class="cursor-pointer font-medium text-brand-ink hover:text-brand-brass transition">
            How quickly can I get a quote?
          </summary>
          <p class="mt-2 text-sm text-brand-ink/70">Most quotes are provided within 24-48 hours. For complex projects, we may schedule a site visit first.</p>
        </details>
        
        <details class="group rounded-2xl bg-brand-sand/40 p-4 shadow-soft">
          <summary class="cursor-pointer font-medium text-brand-ink hover:text-brand-brass transition">
            What should I bring to the showroom?
          </summary>
          <p class="mt-2 text-sm text-brand-ink/70">Room dimensions, photos of your space, and any inspiration images help us provide better guidance.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
<section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="rounded-3xl bg-white p-6 sm:p-8 shadow-soft grid md:grid-cols-2 gap-8 items-start">
      <div>
        <h2 class="font-heading text-2xl sm:text-3xl">Send Us a Message</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">Tell us about your project goals, square footage, timeline, and preferred hardwood tones so we can provide the most useful recommendation quickly.</p>
        <ul class="mt-4 space-y-1 text-sm text-brand-ink/70">
          <li>• European White Oak flooring</li>
          <li>• Installation & design services</li>
          <li>• Renovation timeline planning</li>
          <li>• Product and budget matching</li>
        </ul>
      </div>

      <form class="grid gap-4" aria-label="Contact form" onsubmit="event.preventDefault(); this.reset(); alert('Thanks! We\'ll get back to you shortly.');">
        <div class="grid sm:grid-cols-2 gap-4">
          <label class="block">
            <span class="text-sm">Name</span>
            <input type="text" required class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
          </label>
          <label class="block">
            <span class="text-sm">Email</span>
            <input type="email" required class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
          </label>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <label class="block">
            <span class="text-sm">Phone</span>
            <input type="tel" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
          </label>
          <label class="block">
            <span class="text-sm">ZIP Code</span>
            <input type="text" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
          </label>
        </div>
        <label class="block">
          <span class="text-sm">Project Type</span>
          <select class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
            <option>Hardwood Flooring</option>
            <option>Installation</option>
            <option>Design Services</option>
            <option>Other</option>
          </select>
        </label>
        <label class="block">
          <span class="text-sm">Message</span>
          <textarea rows="5" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak" placeholder="Tell us about your space, timeline, and preferred tones…"></textarea>
        </label>
        <button type="submit" class="mt-2 inline-flex items-center justify-center rounded-2xl bg-brand-brass px-6 py-3 text-white shadow-soft hover:opacity-90 transition">
          Send Message
        </button>
        <p class="text-xs text-brand-ink/60">By submitting, you agree to be contacted about your project. We do not sell your data.</p>
      </form>
    </div>
  </section>

  <!-- Contact Page SEO Content -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-heading text-2xl sm:text-3xl">Looking for the Best Hardwood Flooring Contact in Houston?</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">
          Jamail Hardwoods helps Houston homeowners and interior professionals choose premium hardwood flooring that fits design goals, lifestyle, and budget. Contact our team for showroom appointments, product guidance, and installation planning tailored to your project scope.
        </p>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">
          From modern European White Oak to rich walnut options, we provide clear recommendations and practical next steps so your hardwood flooring project moves forward smoothly.
        </p>
      </div>
    </div>
  </section>

  <!-- JSON-LD: LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "@id": "https://jamailfloors.com/#contact",
    "name": "Jamail Hardwoods",
    "image": "https://jamailfloors.com/assets/og/home.jpg",
    "url": "https://jamailfloors.com/contact/",
    "telephone": "+1-832-930-5936",
    "email": "sales@jamailfloors.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "2643 Colquitt St",
      "addressLocality": "Houston",
      "addressRegion": "TX",
      "postalCode": "77098",
      "addressCountry": "US"
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "10:00",
        "closes": "18:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "10:00",
        "closes": "17:00"
      }
    ],
    "areaServed": [
      "Houston", "River Oaks", "West University Place", "Southside Place", 
      "Woodland Heights", "Afton Oaks", "Hyde Park", "Timbergrove"
    ]
  })}></script>

  <!-- JSON-LD: ContactPage + FAQ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact Jamail Hardwoods",
    "url": "https://jamailfloors.com/contact/",
    "mainEntity": {
      "@type": "Organization",
      "name": "Jamail Hardwoods",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+1-832-930-5936",
        "contactType": "customer service",
        "areaServed": "Houston",
        "availableLanguage": ["English"]
      }
    }
  })}></script>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do I need an appointment to visit Jamail Hardwoods?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Appointments are recommended for dedicated guidance, but walk-ins are welcome during showroom hours."
        }
      },
      {
        "@type": "Question",
        "name": "How quickly can I receive a hardwood flooring quote?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most quotes are provided within 24 to 48 hours depending on project complexity."
        }
      },
      {
        "@type": "Question",
        "name": "What details should I share when contacting Jamail Hardwoods?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Include square footage, timeline, room photos, and style preferences so we can provide accurate recommendations."
        }
      }
    ]
  })}></script>

  <Footer />
</Layout>

