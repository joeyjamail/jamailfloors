---
// the-woodlands.astro - Hardwood Flooring in The Woodlands, TX
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const BOOKING_URL = 'https://jamail-hardwoods-leads.vercel.app/booking';
---

<Layout
  title="Hardwood Flooring in The Woodlands, TX | Jamail Hardwoods"
  description="European white oak flooring for The Woodlands. We serve Creekside Park, Grogan's Mill, Sterling Ridge, Alden Bridge, and Carlton Woods. Free consultation, 4.9★ Houston team."
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Jamail Hardwoods — Serving The Woodlands",
    "url": "https://jamailfloors.com/houston/the-woodlands",
    "telephone": "+1-832-930-5936",
    "address": { "@type": "PostalAddress", "streetAddress": "2643 Colquitt St", "addressLocality": "Houston", "addressRegion": "TX", "postalCode": "77098", "addressCountry": "US" },
    "areaServed": { "@type": "Place", "name": "The Woodlands, TX" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "100" }
  })}></script>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Montgomery County · 77380 / 77381 / 77382</p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Hardwood Flooring in The Woodlands</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">
          European white oak floors for The Woodlands homes — Creekside Park, Grogan's Mill, Sterling Ridge, Alden Bridge, Indian Springs, and Carlton Woods. Yes, we make the drive — we install up here weekly.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={BOOKING_URL}
             class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition"
             target="_blank" rel="nofollow noopener noreferrer">
            Book Free Consultation
          </a>
          <a href="/contact"
             class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">
            Order Free Samples
          </a>
        </div>
        <div class="mt-8 grid grid-cols-3 gap-6 max-w-md">
          <div>
            <div class="font-heading text-2xl text-brand-coal">40+</div>
            <div class="text-xs text-brand-ink/70 mt-1">Woodlands installs</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-brand-coal">Weekly</div>
            <div class="text-xs text-brand-ink/70 mt-1">North-side trips</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-brand-coal">4.9★</div>
            <div class="text-xs text-brand-ink/70 mt-1">Google rating</div>
          </div>
        </div>
      </div>
      <div class="reveal">
        <img src="/images/Hardwood Flooring Houston Jamail Hardwoods.jpg"
             alt="European white oak install in The Woodlands Sterling Ridge home"
             class="aspect-[5/4] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="reveal">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Why The Woodlands chooses Jamail</p>
      <h2 class="font-heading text-2xl sm:text-3xl">The drive's worth it — and we make it weekly</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">
        The Woodlands is 45 minutes north of our Colquitt Street showroom, and a lot of local flooring shops can't or won't make that drive for an in-home consultation. We do — every week. Our trucks are up I-45 several times a week, and we keep installation crews working in the area on rotation, which means we can quote, schedule, and start a project in The Woodlands almost as quickly as one inside the Beltway.
      </p>
      <p class="mt-4 text-brand-ink/80 leading-relaxed">
        We've installed in 40+ Woodlands homes — from forest-edged custom builds in Carlton Woods to remodels in the original villages. The Woodlands tends to draw two project profiles: new-construction owners adding hardwood as a builder upgrade, and longtime residents replacing 90s carpet or tile with wide-plank oak. We handle both.
      </p>
    </div>
    <div class="reveal">
      <img src="/images/Hardwood installing.jpg"
           alt="Recent install in Carlton Woods, The Woodlands"
           class="aspect-[4/3] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">What working with us looks like</p>
        <h2 class="font-heading text-2xl sm:text-3xl">How we run a Woodlands project</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">01</div>
          <h3 class="font-semibold mt-2">Single-trip consultation</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We drive up with samples, measure, and quote in a single appointment. We respect that you didn't move 45 minutes north to schedule three site visits.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">02</div>
          <h3 class="font-semibold mt-2">New-build coordination</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We work with Toll Brothers, David Weekley, Highland Homes, and many of the custom builders in the area. We slot into your build schedule, coordinate with your superintendent, and finish on the day the kitchen lands.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">03</div>
          <h3 class="font-semibold mt-2">Local materials, shorter lead</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We stock our three core collections on the south side and can usually start a Woodlands install within 2–4 weeks of contract signing. No "12-week lead time" surprises.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="reveal rounded-3xl bg-brand-ivory p-8 md:p-12 max-w-3xl mx-auto">
      <div class="text-brand-brass mb-4">★★★★★</div>
      <blockquote class="font-heading text-xl sm:text-2xl text-brand-coal leading-snug italic">
        "We built new in Creekside and the builder's flooring option was a hard pass. Jamail drove up, brought a full sample box, gave us a quote in the room, and installed Sierra Driftwood the week before we moved in. They started early and finished early. We've already recommended them to two neighbors."
      </blockquote>
      <cite class="block mt-5 not-italic text-sm text-brand-ink/70">— Daniel M., The Woodlands (Creekside Park, 77382)</cite>
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Floors that suit The Woodlands</p>
        <h2 class="font-heading text-2xl sm:text-3xl">Our European White Oak — installed locally</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">Each plank is European-milled, engineered for Houston / Montgomery County humidity, and finished low-VOC. Order a free sample box and we'll ship full-size planks anywhere in The Woodlands in 5–7 days.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <a href="/products/harbor-cloud" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/harbor-cloud/harbor-cloud-european-oak-hardwood-floor.jpg" alt="Harbor Cloud European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Harbor Cloud</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Light and airy. Woodlands favorite for new builds with big windows.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Harbor Cloud →</span>
          </div>
        </a>
        <a href="/products/amber-canyon" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/amber-canyon/amber-canyon-european-oak-hardwood-floor.jpg" alt="Amber Canyon European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Amber Canyon</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Warm and characterful. Right at home in tree-shaded Sterling Ridge.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Amber Canyon →</span>
          </div>
        </a>
        <a href="/products/sierra-driftwood" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/sierra-driftwood/sierra-driftwood-european-oak-hardwood-floor.jpg" alt="Sierra Driftwood European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Sierra Driftwood</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Weathered gray-brown. Most-installed across Montgomery County.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Sierra Driftwood →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Areas we serve</p>
      <h2 class="font-heading text-2xl sm:text-3xl">The Woodlands and Montgomery County</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">All of the master-planned villages plus surrounding north Houston:</p>
    </div>
    <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 max-w-2xl text-brand-ink/80">
      <li>Creekside Park (77389)</li>
      <li>Grogan's Mill (77380)</li>
      <li>Sterling Ridge (77382)</li>
      <li>Alden Bridge (77382)</li>
      <li>Indian Springs (77382)</li>
      <li>Carlton Woods</li>
      <li>Panther Creek (77381)</li>
      <li>Spring (77386 / 77389)</li>
    </ul>
    <p class="mt-6 text-brand-ink/80 max-w-2xl">Live in Conroe, Magnolia, or Tomball? <a href="/contact" class="text-brand-brass hover:underline">Ask</a> — we can usually accommodate.</p>
  </section>

  <section class="bg-brand-ink text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 text-center max-w-2xl">
      <h2 class="font-heading text-2xl sm:text-3xl">Let's look at your floors</h2>
      <p class="mt-3 text-white/80 leading-relaxed">Free in-home consultation anywhere in The Woodlands. We come to you, bring samples, measure, and follow up with a written quote within 48 hours. Single trip, no pressure.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href={BOOKING_URL}
           class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-6 py-3 text-white shadow-soft hover:opacity-90 transition"
           target="_blank" rel="nofollow noopener noreferrer">
          Book Free Consultation
        </a>
        <a href="tel:+18329305936"
           class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">
          Call (832) 930-5936
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
