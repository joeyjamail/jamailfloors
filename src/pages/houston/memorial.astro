---
// memorial.astro - Hardwood Flooring in Memorial, Houston
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const BOOKING_URL = 'https://jamail-hardwoods-leads.vercel.app/booking';
---

<Layout
  title="Hardwood Flooring in Memorial, Houston | Jamail Hardwoods"
  description="European white oak flooring for Memorial homes — Memorial Villages, Bunker Hill, Hedwig Village, Piney Point. Local install team. Free consultation. 4.9★."
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Jamail Hardwoods — Serving Memorial",
    "url": "https://jamailfloors.com/houston/memorial",
    "telephone": "+1-832-930-5936",
    "address": { "@type": "PostalAddress", "streetAddress": "2643 Colquitt St", "addressLocality": "Houston", "addressRegion": "TX", "postalCode": "77098", "addressCountry": "US" },
    "areaServed": { "@type": "Place", "name": "Memorial, Houston, TX" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "100" }
  })}></script>

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Houston · 77024 / 77079</p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Hardwood Flooring in Memorial</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">
          European white oak floors for Memorial homes — Memorial Villages, Bunker Hill, Hedwig Village, Piney Point, and west toward Energy Corridor. Family-friendly, low-VOC, installed by a team based 15 minutes east on Colquitt.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={BOOKING_URL}
             class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition"
             target="_blank" rel="nofollow noopener noreferrer">
            Book Free Consultation
          </a>
          <a href="/contact"
             class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">
            Order Free Samples
          </a>
        </div>
        <div class="mt-8 grid grid-cols-3 gap-6 max-w-md">
          <div>
            <div class="font-heading text-2xl text-brand-coal">75+</div>
            <div class="text-xs text-brand-ink/70 mt-1">Memorial installs</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-brand-coal">15 min</div>
            <div class="text-xs text-brand-ink/70 mt-1">From showroom</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-brand-coal">4.9★</div>
            <div class="text-xs text-brand-ink/70 mt-1">Google rating</div>
          </div>
        </div>
      </div>
      <div class="reveal">
        <img src="/images/Hardwood Flooring Houston Jamail Hardwoods.jpg"
             alt="Wide plank European white oak floor in a Memorial Houston family room"
             class="aspect-[5/4] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="reveal">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Why Memorial chooses Jamail</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Built for big homes, big families, and big floors</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">
        Memorial homes are typically larger than the inner-loop average — 3,500 to 6,000+ sq ft of living space, often spread over two stories with an open downstairs. That means whole-floor installs, careful seam planning across long sightlines, and a lot of square footage where small mistakes become big visible problems.
      </p>
      <p class="mt-4 text-brand-ink/80 leading-relaxed">
        We've installed in 75+ Memorial homes — and a significant percentage of that work is whole-downstairs replacements: tile out, hardwood in, kitchen island flush, transitions cleaner than the originals. Memorial families also tend to have kids, dogs, and grandparents who live in the house — so the floors have to be quiet, scratch-resistant, and easy to live on. European white oak in a matte finish is the answer for almost every one of those projects.
      </p>
    </div>
    <div class="reveal">
      <img src="/images/Hardwood installing.jpg"
           alt="Recent install in Bunker Hill Village"
           class="aspect-[4/3] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">What working with us looks like</p>
        <h2 class="font-heading text-2xl sm:text-3xl">How we run a Memorial project</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">01</div>
          <h3 class="font-semibold mt-2">Whole-downstairs planning</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We map plank direction, seam placement, and transitions before demo. Long sightlines need a plan — we measure twice and walk the layout with you before a single board is glued.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">02</div>
          <h3 class="font-semibold mt-2">Live-through-the-install option</h3>
          <p class="mt-1 text-sm text-brand-ink/70">HEPA dust containment, rolling barriers between active rooms and untouched rooms, and clean walkways nightly. Most Memorial families stay in the house the whole install — kitchen, pets, and all.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">03</div>
          <h3 class="font-semibold mt-2">Honest timelines</h3>
          <p class="mt-1 text-sm text-brand-ink/70">A 3,500 sq ft downstairs takes 7–10 working days, not 3. We won't pretend otherwise. What we will do is finish on the day we promised — or earlier.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="reveal rounded-3xl bg-brand-ivory p-8 md:p-12 max-w-3xl mx-auto">
      <div class="text-brand-brass mb-4">★★★★★</div>
      <blockquote class="font-heading text-xl sm:text-2xl text-brand-coal leading-snug italic">
        "3,800 sq ft of European white oak across the entire downstairs of our Bunker Hill home. We have two kids and a Lab and we lived in the house the entire time. The dust control was incredible. Six months in and the floors look like the day they finished."
      </blockquote>
      <cite class="block mt-5 not-italic text-sm text-brand-ink/70">— Michelle R., Memorial (77024)</cite>
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Floors that suit Memorial</p>
        <h2 class="font-heading text-2xl sm:text-3xl">Our European White Oak — installed locally</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">Each plank is European-milled, engineered for Houston humidity, and finished low-VOC. Order a free sample box and we'll ship full-size planks to your Memorial address in 5–7 days.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <a href="/products/harbor-cloud" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/harbor-cloud/harbor-cloud-european-oak-hardwood-floor.jpg" alt="Harbor Cloud European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Harbor Cloud</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Light and airy. Makes big rooms feel even bigger.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Harbor Cloud →</span>
          </div>
        </a>
        <a href="/products/amber-canyon" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/amber-canyon/amber-canyon-european-oak-hardwood-floor.jpg" alt="Amber Canyon European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Amber Canyon</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Warm and characterful. Hides daily wear in busy family homes.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Amber Canyon →</span>
          </div>
        </a>
        <a href="/products/sierra-driftwood" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/sierra-driftwood/sierra-driftwood-european-oak-hardwood-floor.jpg" alt="Sierra Driftwood European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Sierra Driftwood</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Weathered gray-brown. Rustic character for modern interiors.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Sierra Driftwood →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Areas we serve</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Memorial and the western villages</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">Our showroom is 15 minutes east of Memorial Drive. We routinely serve:</p>
    </div>
    <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 max-w-2xl text-brand-ink/80">
      <li>Memorial (77024)</li>
      <li>Bunker Hill Village</li>
      <li>Hedwig Village</li>
      <li>Piney Point Village</li>
      <li>Hunters Creek Village</li>
      <li>Spring Branch (77055)</li>
      <li>Energy Corridor (77079)</li>
      <li>Briargrove</li>
    </ul>
    <p class="mt-6 text-brand-ink/80 max-w-2xl">Not seeing your street? <a href="/contact" class="text-brand-brass hover:underline">Just ask</a> — Memorial Park to Eldridge Parkway is well within range.</p>
  </section>

  <section class="bg-brand-ink text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 text-center max-w-2xl">
      <h2 class="font-heading text-2xl sm:text-3xl">Let's look at your floors</h2>
      <p class="mt-3 text-white/80 leading-relaxed">Free in-home consultation anywhere in Memorial. We'll bring full-size sample planks, measure your space, and follow up with a written estimate within 48 hours. No high-pressure pitch.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href={BOOKING_URL}
           class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-6 py-3 text-white shadow-soft hover:opacity-90 transition"
           target="_blank" rel="nofollow noopener noreferrer">
          Book Free Consultation
        </a>
        <a href="tel:+18329305936"
           class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">
          Call (832) 930-5936
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
