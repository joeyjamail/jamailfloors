---
// river-oaks.astro - Hardwood Flooring in River Oaks, Houston
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const BOOKING_URL = 'https://jamail-hardwoods-leads.vercel.app/booking';
---

<Layout
  title="Hardwood Flooring in River Oaks, Houston | Jamail Hardwoods"
  description="European white oak flooring for River Oaks homes. Local installation specialists with showroom 10 minutes away. Free in-home consultation. 4.9★ Google rating."
>
  <Header />

  <!-- JSON-LD: LocalBusiness for River Oaks service area -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Jamail Hardwoods — Serving River Oaks",
    "image": "https://jamailfloors.com/images/Hardwood Flooring Houston Jamail Hardwoods.jpg",
    "url": "https://jamailfloors.com/houston/river-oaks",
    "telephone": "+1-832-930-5936",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "2643 Colquitt St",
      "addressLocality": "Houston",
      "addressRegion": "TX",
      "postalCode": "77098",
      "addressCountry": "US"
    },
    "areaServed": { "@type": "Place", "name": "River Oaks, Houston, TX" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "100" }
  })}></script>

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Houston · 77019</p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Hardwood Flooring in River Oaks</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">
          European white oak floors for River Oaks homes, installed by a team based 10 minutes away on Colquitt Street. We work with both stately traditional renovations and modern new builds — from Inwood Drive to Lazy Lane.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={BOOKING_URL}
             class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition"
             target="_blank" rel="nofollow noopener noreferrer">
            Book Free Consultation
          </a>
          <a href="/contact"
             class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">
            Order Free Samples
          </a>
        </div>
        <div class="mt-8 grid grid-cols-3 gap-6 max-w-md">
          <div>
            <div class="font-heading text-2xl text-brand-coal">60+</div>
            <div class="text-xs text-brand-ink/70 mt-1">River Oaks installs</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-brand-coal">10 min</div>
            <div class="text-xs text-brand-ink/70 mt-1">From showroom</div>
          </div>
          <div>
            <div class="font-heading text-2xl text-brand-coal">4.9★</div>
            <div class="text-xs text-brand-ink/70 mt-1">Google rating</div>
          </div>
        </div>
      </div>
      <div class="reveal">
        <img src="/images/Hardwood Flooring Houston Jamail Hardwoods.jpg"
             alt="European white oak hardwood floor installed in a River Oaks Houston home"
             class="aspect-[5/4] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
      </div>
    </div>
  </section>

  <!-- Why River Oaks chooses Jamail -->
  <section class="container mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="reveal">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Why River Oaks chooses Jamail</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Built for the homes that defined Houston</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">
        River Oaks homes are different. Many are pre-war or mid-century originals being lovingly restored. Others are recent rebuilds where the architecture is contemporary but the expectation is still craft. Either way, the floors matter — and most national chains aren't equipped for the level of detail River Oaks projects demand.
      </p>
      <p class="mt-4 text-brand-ink/80 leading-relaxed">
        We've installed European white oak in 60+ River Oaks homes since 2015. We understand the architectural standards, the HOA quirks, the parking constraints, and the level of finish work that residents and their designers expect. Most of our River Oaks work comes from referrals — from clients, from interior designers, and from neighbors who saw the truck and the moving blankets and asked who we were.
      </p>
    </div>
    <div class="reveal">
      <img src="/images/Hardwood installing.jpg"
           alt="Recent hardwood install on Inwood Drive in River Oaks"
           class="aspect-[4/3] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
    </div>
  </section>

  <!-- How we run a River Oaks project -->
  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">What working with us looks like</p>
        <h2 class="font-heading text-2xl sm:text-3xl">How we run a River Oaks project</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">01</div>
          <h3 class="font-semibold mt-2">In-home consultation</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We come to you. Look at the rooms, the light, the existing finishes. Bring sample boards and answer the questions you should be asking. Free, no follow-up pressure.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">02</div>
          <h3 class="font-semibold mt-2">Discrete, dust-controlled install</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We're used to occupied homes. HEPA dust containment, daily cleanup, blue-tape protection of trim and stone. We've worked alongside other trades on multi-phase renovations without ever being the problem.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">03</div>
          <h3 class="font-semibold mt-2">Long-term relationship</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We're here. When you have a question about the floor a year later — a scratch, a refinish, a question about a wet rug — call us. We don't disappear after the check clears.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="reveal rounded-3xl bg-brand-ivory p-8 md:p-12 max-w-3xl mx-auto">
      <div class="text-brand-brass mb-4">★★★★★</div>
      <blockquote class="font-heading text-xl sm:text-2xl text-brand-coal leading-snug italic">
        "We did a full down-to-studs renovation on a 1940s house on Inwood. The Jamail team worked alongside our GC, our designer, and four other trades for almost a year and never once caused a problem. The floors look like they belonged in the house since 1940."
      </blockquote>
      <cite class="block mt-5 not-italic text-sm text-brand-ink/70">— Hassan M., River Oaks (77019)</cite>
    </div>
  </section>

  <!-- Collections that suit River Oaks -->
  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Floors that suit River Oaks</p>
        <h2 class="font-heading text-2xl sm:text-3xl">Our European White Oak — installed locally</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">Each plank is European-milled, engineered for Houston humidity, and finished low-VOC. Order a free sample box and we'll ship full-size planks to your River Oaks address in 5–7 days.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <a href="/products/harbor-cloud" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/harbor-cloud/harbor-cloud-european-oak-hardwood-floor.jpg"
               alt="Harbor Cloud European white oak"
               class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Harbor Cloud</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Light and airy. The pick for renovations adding brightness.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Harbor Cloud →</span>
          </div>
        </a>
        <a href="/products/amber-canyon" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/amber-canyon/amber-canyon-european-oak-hardwood-floor.jpg"
               alt="Amber Canyon European white oak"
               class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Amber Canyon</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Warm and honey-toned. Beautiful in traditional homes.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Amber Canyon →</span>
          </div>
        </a>
        <a href="/products/sierra-driftwood" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/sierra-driftwood/sierra-driftwood-european-oak-hardwood-floor.jpg"
               alt="Sierra Driftwood European white oak"
               class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Sierra Driftwood</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Weathered gray-brown. Rustic character for modern interiors.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Sierra Driftwood →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Areas we serve</p>
      <h2 class="font-heading text-2xl sm:text-3xl">River Oaks and nearby neighborhoods</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">Our showroom is 2.5 miles from the River Oaks Country Club. We routinely serve:</p>
    </div>
    <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 max-w-2xl text-brand-ink/80">
      <li>River Oaks (77019)</li>
      <li>River Oaks Estates</li>
      <li>Lazy Lane Boulevard</li>
      <li>Inwood Drive</li>
      <li>Tanglewood</li>
      <li>Afton Oaks</li>
      <li>Greenway / Upper Kirby</li>
      <li>West University Place</li>
    </ul>
    <p class="mt-6 text-brand-ink/80 max-w-2xl">Not seeing your street? Most of Greater Houston is within our standard service area — <a href="/contact" class="text-brand-brass hover:underline">just ask</a>.</p>
  </section>

  <!-- Big CTA -->
  <section class="bg-brand-ink text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 text-center max-w-2xl">
      <h2 class="font-heading text-2xl sm:text-3xl">Let's look at your floors</h2>
      <p class="mt-3 text-white/80 leading-relaxed">Free in-home consultation in River Oaks. We'll bring sample boards, measure, talk through your project, and email you a written estimate within 48 hours. No high-pressure pitch.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href={BOOKING_URL}
           class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-6 py-3 text-white shadow-soft hover:opacity-90 transition"
           target="_blank" rel="nofollow noopener noreferrer">
          Book Free Consultation
        </a>
        <a href="tel:+18329305936"
           class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">
          Call (832) 930-5936
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
