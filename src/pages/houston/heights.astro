---
// heights.astro - Hardwood Flooring in Heights, Houston
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const BOOKING_URL = 'https://jamail-hardwoods-leads.vercel.app/booking';
---

<Layout
  title="Hardwood Flooring in Heights, Houston | Jamail Hardwoods"
  description="European white oak hardwood flooring for Heights homes. Local Houston installation specialists, free in-home consultation, 4.9★ Google rating."
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Jamail Hardwoods — Serving Heights",
    "url": "https://jamailfloors.com/houston/heights",
    "telephone": "+1-832-930-5936",
    "address": { "@type": "PostalAddress", "streetAddress": "2643 Colquitt St", "addressLocality": "Houston", "addressRegion": "TX", "postalCode": "77098", "addressCountry": "US" },
    "areaServed": { "@type": "Place", "name": "The Heights, Houston, TX" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "100" }
  })}></script>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Inner Loop · 77007 / 77008 / 77009</p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Hardwood Flooring in The Heights</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">European white oak floors for Heights homes — historic 1900s bungalows, modern townhomes, restored Victorians. Installed by a Houston team that understands what makes Heights renovations special. 15 minutes south on Heights Boulevard.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={BOOKING_URL} class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition" target="_blank" rel="nofollow noopener noreferrer">Book Free Consultation</a>
          <a href="/contact" class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">Order Free Samples</a>
        </div>
        <div class="mt-8 grid grid-cols-3 gap-6 max-w-md">
          <div><div class="font-heading text-2xl text-brand-coal">60+</div><div class="text-xs text-brand-ink/70 mt-1">Heights installs</div></div>
          <div><div class="font-heading text-2xl text-brand-coal">15 min</div><div class="text-xs text-brand-ink/70 mt-1">From showroom</div></div>
          <div><div class="font-heading text-2xl text-brand-coal">4.9★</div><div class="text-xs text-brand-ink/70 mt-1">Google rating</div></div>
        </div>
      </div>
      <div class="reveal">
        <img src="/images/Hardwood Flooring Houston Jamail Hardwoods.jpg" alt="European white oak hardwood floor installed in a Heights Houston home" class="aspect-[5/4] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="reveal">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Why The Heights chooses Jamail</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Built for Houston's most historic neighborhood</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">The Heights is unlike any other Houston neighborhood — pre-1920 bungalows, Craftsman porches, original heart-pine floors, and decades of careful restoration alongside contemporary infill townhomes. The Heights is also one of Houston's most design-conscious neighborhoods. People here care about getting renovation details right.</p>
      <p class="mt-4 text-brand-ink/80 leading-relaxed">60+ Heights installs. We've worked on restorations where keeping the original baseboards mattered as much as the new floors, and on modern Heights townhomes where wide-plank European oak completes the contemporary aesthetic. We work alongside Heights designers, GCs, and restoration specialists routinely.</p>
    </div>
    <div class="reveal">
      <img src="/images/Hardwood installing.jpg" alt="Recent hardwood install in Heights" class="aspect-[4/3] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">What working with us looks like</p>
        <h2 class="font-heading text-2xl sm:text-3xl">How we run a Heights project</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">01</div>
          <h3 class="font-semibold mt-2">Historic restoration sensitivity</h3>
          <p class="mt-1 text-sm text-brand-ink/70">Pre-1920 Heights bungalows often have settled subfloors, original heart-pine that needs preservation in some rooms, period-appropriate trim, and tight space constraints. We've handled all of it — including saving original floors in some rooms while installing new in others.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">02</div>
          <h3 class="font-semibold mt-2">Townhome and infill coordination</h3>
          <p class="mt-1 text-sm text-brand-ink/70">Heights townhome rows present their own challenges: shared walls, tight parking, HOA-adjacent rules, narrow stairwells. We're set up for it — small crew, smart material staging, dust containment that protects neighbors.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">03</div>
          <h3 class="font-semibold mt-2">Designer collaboration</h3>
          <p class="mt-1 text-sm text-brand-ink/70">Many Heights projects flow through interior designers. We bring physical samples to the designer's studio, execute to spec, and handle every transition piece carefully. Heights designers know our work.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="reveal rounded-3xl bg-brand-ivory p-8 md:p-12 max-w-3xl mx-auto">
      <div class="text-brand-brass mb-4">★★★★★</div>
      <blockquote class="font-heading text-xl sm:text-2xl text-brand-coal leading-snug italic">"We renovated a 1915 Heights bungalow — kept the front porch, the original windows, the heart-pine in the living room. Jamail installed Sierra Driftwood in the kitchen and added rooms, matching the trim profile and step-down to the original floors perfectly. Looks like it was always there."</blockquote>
      <cite class="block mt-5 not-italic text-sm text-brand-ink/70">— Beverly S., The Heights (77008)</cite>
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Floors that suit Heights</p>
        <h2 class="font-heading text-2xl sm:text-3xl">Our European White Oak — installed locally</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">Order a free sample box and we'll ship full-size planks to your Heights address in 5–7 days.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <a href="/products/harbor-cloud" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/harbor-cloud/harbor-cloud-european-oak-hardwood-floor.jpg" alt="Harbor Cloud European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Harbor Cloud</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Light and airy. Brightens any space.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Harbor Cloud →</span>
          </div>
        </a>
        <a href="/products/amber-canyon" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/amber-canyon/amber-canyon-european-oak-hardwood-floor.jpg" alt="Amber Canyon European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Amber Canyon</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Warm and characterful. Hides daily wear beautifully.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Amber Canyon →</span>
          </div>
        </a>
        <a href="/products/sierra-driftwood" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/sierra-driftwood/sierra-driftwood-european-oak-hardwood-floor.jpg" alt="Sierra Driftwood European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Sierra Driftwood</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Weathered gray-brown. Most-installed across Houston.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Sierra Driftwood →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Areas we serve</p>
      <h2 class="font-heading text-2xl sm:text-3xl">The Heights and surrounding inner-loop north</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">We're 15 minutes south of Heights Boulevard. We routinely serve:</p>
    </div>
    <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 max-w-2xl text-brand-ink/80">
      <li>Heights (77008)</li>
      <li>Houston Heights Historic District</li>
      <li>Woodland Heights (77009)</li>
      <li>Norhill Historic District</li>
      <li>Sunset Heights (77007)</li>
      <li>Greater Heights</li>
      <li>Cottage Grove</li>
      <li>Timbergrove / Lazybrook</li>
    </ul>
    <p class="mt-6 text-brand-ink/80 max-w-2xl">Adjacent: Garden Oaks, Independence Heights, Acres Homes, and inner-loop north.</p>
  </section>

  <section class="bg-brand-ink text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 text-center max-w-2xl">
      <h2 class="font-heading text-2xl sm:text-3xl">Let's look at your floors</h2>
      <p class="mt-3 text-white/80 leading-relaxed">Free in-home consultation in The Heights. We come to you, look at the bungalow / townhome / new build context, and email a written estimate within 48 hours. We work well with designers and restoration GCs.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href={BOOKING_URL} class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-6 py-3 text-white shadow-soft hover:opacity-90 transition" target="_blank" rel="nofollow noopener noreferrer">Book Free Consultation</a>
        <a href="tel:+18329305936" class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">Call (832) 930-5936</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
