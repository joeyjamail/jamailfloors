---
// spring-branch.astro - Hardwood Flooring in Spring Branch, Houston
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const BOOKING_URL = 'https://jamail-hardwoods-leads.vercel.app/booking';
---

<Layout
  title="Hardwood Flooring in Spring Branch, Houston | Jamail Hardwoods"
  description="European white oak hardwood flooring for Spring Branch homes. Local Houston installation specialists, free in-home consultation, 4.9★ Google rating."
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Jamail Hardwoods — Serving Spring Branch",
    "url": "https://jamailfloors.com/houston/spring-branch",
    "telephone": "+1-832-930-5936",
    "address": { "@type": "PostalAddress", "streetAddress": "2643 Colquitt St", "addressLocality": "Houston", "addressRegion": "TX", "postalCode": "77098", "addressCountry": "US" },
    "areaServed": { "@type": "Place", "name": "Spring Branch, Houston, TX" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "100" }
  })}></script>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Northwest Houston · 77055 / 77080</p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Hardwood Flooring in Spring Branch</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">European white oak floors for Spring Branch homes — between the Beltway and Memorial, north of I-10. Classic mid-century ranches, modern infill homes, and family-friendly streets. Installed by a Houston team 15 minutes away on Colquitt Street.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={BOOKING_URL} class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition" target="_blank" rel="nofollow noopener noreferrer">Book Free Consultation</a>
          <a href="/contact" class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">Order Free Samples</a>
        </div>
        <div class="mt-8 grid grid-cols-3 gap-6 max-w-md">
          <div><div class="font-heading text-2xl text-brand-coal">45+</div><div class="text-xs text-brand-ink/70 mt-1">Spring Branch installs</div></div>
          <div><div class="font-heading text-2xl text-brand-coal">15 min</div><div class="text-xs text-brand-ink/70 mt-1">From showroom</div></div>
          <div><div class="font-heading text-2xl text-brand-coal">4.9★</div><div class="text-xs text-brand-ink/70 mt-1">Google rating</div></div>
        </div>
      </div>
      <div class="reveal">
        <img src="/images/Hardwood Flooring Houston Jamail Hardwoods.jpg" alt="European white oak hardwood floor installed in a Spring Branch Houston home" class="aspect-[5/4] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="reveal">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Why Spring Branch chooses Jamail</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Built for Spring Branch's evolving neighborhood</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">Spring Branch is one of Houston's most diverse residential neighborhoods — original 1950s-60s ranch homes sit next to brand-new modern infills, and prices and lot sizes vary across the same street. The renovation rate here is high: families upgrading older homes, builders modernizing tear-downs, longtime residents replacing 70s carpet with hardwood. Floors are usually the first major upgrade.</p>
      <p class="mt-4 text-brand-ink/80 leading-relaxed">45+ Spring Branch installs. Our crews work this area weekly — we're 15 minutes east via Long Point or Westview. We've done full-house renovations on Bingle, Wirt, Pech, Campbell, and across the broader Spring Branch ISD area.</p>
    </div>
    <div class="reveal">
      <img src="/images/Hardwood installing.jpg" alt="Recent hardwood install in Spring Branch" class="aspect-[4/3] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">What working with us looks like</p>
        <h2 class="font-heading text-2xl sm:text-3xl">How we run a Spring Branch project</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">01</div>
          <h3 class="font-semibold mt-2">Mid-century ranch expertise</h3>
          <p class="mt-1 text-sm text-brand-ink/70">1950s and 60s Spring Branch homes often have settled slabs, original baseboards we work hard to preserve, and quirky room layouts. We've done dozens — slab grinding, moisture mitigation, careful trim protection.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">02</div>
          <h3 class="font-semibold mt-2">Modern infill coordination</h3>
          <p class="mt-1 text-sm text-brand-ink/70">For Spring Branch's new builds and tear-down rebuilds, we coordinate directly with the GC and architect. Wide-plank European oak fits the modern aesthetic; we handle the long sightlines and clean lines those builds require.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">03</div>
          <h3 class="font-semibold mt-2">Family-friendly install</h3>
          <p class="mt-1 text-sm text-brand-ink/70">Spring Branch has tight-knit streets and a lot of young families. We use HEPA dust containment, work neighbor-aware hours, and plan around school pickup. No street complaints.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="reveal rounded-3xl bg-brand-ivory p-8 md:p-12 max-w-3xl mx-auto">
      <div class="text-brand-brass mb-4">★★★★★</div>
      <blockquote class="font-heading text-xl sm:text-2xl text-brand-coal leading-snug italic">"Our 1958 ranch on Bingle needed a full update. Jamail installed Harbor Cloud across the whole downstairs — the slab needed work, the trim is original. They protected everything, finished on time, and the floors completely changed the feel of the house."</blockquote>
      <cite class="block mt-5 not-italic text-sm text-brand-ink/70">— Aaron K., Spring Branch (77055)</cite>
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Floors that suit Spring Branch</p>
        <h2 class="font-heading text-2xl sm:text-3xl">Our European White Oak — installed locally</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">Order a free sample box and we'll ship full-size planks to your Spring Branch address in 5–7 days.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <a href="/products/harbor-cloud" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/harbor-cloud/harbor-cloud-european-oak-hardwood-floor.jpg" alt="Harbor Cloud European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Harbor Cloud</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Light and airy. Brightens any space.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Harbor Cloud →</span>
          </div>
        </a>
        <a href="/products/amber-canyon" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/amber-canyon/amber-canyon-european-oak-hardwood-floor.jpg" alt="Amber Canyon European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Amber Canyon</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Warm and characterful. Hides daily wear beautifully.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Amber Canyon →</span>
          </div>
        </a>
        <a href="/products/sierra-driftwood" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/sierra-driftwood/sierra-driftwood-european-oak-hardwood-floor.jpg" alt="Sierra Driftwood European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Sierra Driftwood</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Weathered gray-brown. Most-installed across Houston.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Sierra Driftwood →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Areas we serve</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Spring Branch and Northwest Houston</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">Our trucks make weekly trips through Long Point. We routinely serve:</p>
    </div>
    <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 max-w-2xl text-brand-ink/80">
      <li>Spring Branch (77055)</li>
      <li>Spring Branch West (77080)</li>
      <li>Spring Branch East</li>
      <li>Long Point corridor</li>
      <li>Westview corridor</li>
      <li>Bingle / Pech / Wirt</li>
      <li>Hilshire Village</li>
      <li>Hedwig Village (77024)</li>
    </ul>
    <p class="mt-6 text-brand-ink/80 max-w-2xl">Adjacent: Memorial, Hedwig, Hilshire Village, Northwest Houston, Heights-adjacent streets.</p>
  </section>

  <section class="bg-brand-ink text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 text-center max-w-2xl">
      <h2 class="font-heading text-2xl sm:text-3xl">Let's look at your floors</h2>
      <p class="mt-3 text-white/80 leading-relaxed">Free in-home consultation in Spring Branch. We come to you, measure, look at your slab or subfloor, and email a written estimate within 48 hours.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href={BOOKING_URL} class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-6 py-3 text-white shadow-soft hover:opacity-90 transition" target="_blank" rel="nofollow noopener noreferrer">Book Free Consultation</a>
        <a href="tel:+18329305936" class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">Call (832) 930-5936</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
