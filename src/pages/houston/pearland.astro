---
// pearland.astro - Hardwood Flooring in Pearland, Houston
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const BOOKING_URL = 'https://jamail-hardwoods-leads.vercel.app/booking';
---

<Layout
  title="Hardwood Flooring in Pearland, Houston | Jamail Hardwoods"
  description="European white oak hardwood flooring for Pearland homes. Local Houston installation specialists, free in-home consultation, 4.9★ Google rating."
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Jamail Hardwoods — Serving Pearland",
    "url": "https://jamailfloors.com/houston/pearland",
    "telephone": "+1-832-930-5936",
    "address": { "@type": "PostalAddress", "streetAddress": "2643 Colquitt St", "addressLocality": "Houston", "addressRegion": "TX", "postalCode": "77098", "addressCountry": "US" },
    "areaServed": { "@type": "Place", "name": "Pearland, TX" },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "100" }
  })}></script>

  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">South Houston · 77581 / 77584</p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Hardwood Flooring in Pearland</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">European white oak floors for Pearland homes — Silverlake, Shadow Creek Ranch, Southern Trails, and across master-planned south Houston. New construction installs, builder-floor replacements, and family-home renovations. Installed by a Houston team that drives south weekly.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={BOOKING_URL} class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition" target="_blank" rel="nofollow noopener noreferrer">Book Free Consultation</a>
          <a href="/contact" class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">Order Free Samples</a>
        </div>
        <div class="mt-8 grid grid-cols-3 gap-6 max-w-md">
          <div><div class="font-heading text-2xl text-brand-coal">35+</div><div class="text-xs text-brand-ink/70 mt-1">Pearland installs</div></div>
          <div><div class="font-heading text-2xl text-brand-coal">30 min</div><div class="text-xs text-brand-ink/70 mt-1">From showroom</div></div>
          <div><div class="font-heading text-2xl text-brand-coal">4.9★</div><div class="text-xs text-brand-ink/70 mt-1">Google rating</div></div>
        </div>
      </div>
      <div class="reveal">
        <img src="/images/Hardwood Flooring Houston Jamail Hardwoods.jpg" alt="European white oak hardwood floor installed in a Pearland Houston home" class="aspect-[5/4] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16 grid md:grid-cols-2 gap-10 items-center">
    <div class="reveal">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Why Pearland chooses Jamail</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Built for Pearland's master-planned communities</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">Pearland is one of Houston's fastest-growing south-side cities — Silverlake, Shadow Creek Ranch, Southern Trails, and dozens of newer master-planned subdivisions full of 2,500–5,000 sq ft family homes. Like Katy and Sugar Land, many Pearland homes shipped with builder-grade LVT or carpet, and homeowners upgrade within a few years.</p>
      <p class="mt-4 text-brand-ink/80 leading-relaxed">35+ Pearland projects under our belt. Our crews drive 288 South multiple times a week. Pearland projects typically split between new-construction floor upgrades (before move-in) and replace-the-builder-floor renovations once the homeowner has lived in the house and decided real hardwood is worth it.</p>
    </div>
    <div class="reveal">
      <img src="/images/Hardwood installing.jpg" alt="Recent hardwood install in Pearland" class="aspect-[4/3] w-full h-full object-cover rounded-3xl shadow-glass" loading="lazy" decoding="async">
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">What working with us looks like</p>
        <h2 class="font-heading text-2xl sm:text-3xl">How we run a Pearland project</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">01</div>
          <h3 class="font-semibold mt-2">Builder-floor replacement specialty</h3>
          <p class="mt-1 text-sm text-brand-ink/70">Most Pearland projects are LVT or carpet rip-outs. We're efficient at this — clean demo, fast slab prep, replace with wide-plank European oak in 5–7 working days. The before/after impact is dramatic.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">02</div>
          <h3 class="font-semibold mt-2">New-build coordination</h3>
          <p class="mt-1 text-sm text-brand-ink/70">We work with Pearland's custom and semi-custom builders — Perry Homes, Beazer, Highland, Coventry. We slot into your build schedule and finish on the day the kitchen lands so you move into a fully-floored home.</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-6 shadow-soft">
          <div class="font-heading text-brand-brass text-2xl">03</div>
          <h3 class="font-semibold mt-2">Family-aware install</h3>
          <p class="mt-1 text-sm text-brand-ink/70">Pearland is heavily family-oriented. Kids, dogs, school schedules, in-laws living in the house. We use HEPA dust containment, sequence rooms to keep kitchens and bedrooms accessible, and work around your family's rhythm.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="reveal rounded-3xl bg-brand-ivory p-8 md:p-12 max-w-3xl mx-auto">
      <div class="text-brand-brass mb-4">★★★★★</div>
      <blockquote class="font-heading text-xl sm:text-2xl text-brand-coal leading-snug italic">"Bought a 4-year-old home in Silverlake with builder LVT. After two kids and a Lab, the LVT was scratched, dented, and curling at the edges. Jamail replaced it all with Sierra Driftwood — 2,400 sq ft, ten days, completely transformed the house. Five years later, still flawless."</blockquote>
      <cite class="block mt-5 not-italic text-sm text-brand-ink/70">— Daniel M., Pearland (Silverlake, 77584)</cite>
    </div>
  </section>

  <section class="bg-brand-sand/40 py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Floors that suit Pearland</p>
        <h2 class="font-heading text-2xl sm:text-3xl">Our European White Oak — installed locally</h2>
        <p class="mt-3 text-brand-ink/80 leading-relaxed">Order a free sample box and we'll ship full-size planks to your Pearland address in 5–7 days.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        <a href="/products/harbor-cloud" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/harbor-cloud/harbor-cloud-european-oak-hardwood-floor.jpg" alt="Harbor Cloud European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Harbor Cloud</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Light and airy. Brightens any space.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Harbor Cloud →</span>
          </div>
        </a>
        <a href="/products/amber-canyon" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/amber-canyon/amber-canyon-european-oak-hardwood-floor.jpg" alt="Amber Canyon European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Amber Canyon</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Warm and characterful. Hides daily wear beautifully.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Amber Canyon →</span>
          </div>
        </a>
        <a href="/products/sierra-driftwood" class="reveal group rounded-2xl bg-white overflow-hidden shadow-soft hover:shadow-glass transition">
          <img src="/images/Products/sierra-driftwood/sierra-driftwood-european-oak-hardwood-floor.jpg" alt="Sierra Driftwood European white oak" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async">
          <div class="p-5">
            <h3 class="font-heading text-xl text-brand-coal">Sierra Driftwood</h3>
            <p class="mt-1 text-sm text-brand-ink/70">Weathered gray-brown. Most-installed across Houston.</p>
            <span class="inline-block mt-3 text-sm font-semibold text-brand-brass group-hover:underline">View Sierra Driftwood →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Areas we serve</p>
      <h2 class="font-heading text-2xl sm:text-3xl">Pearland and south Houston</h2>
      <p class="mt-3 text-brand-ink/80 leading-relaxed">Our trucks make weekly trips down 288 South. We routinely serve:</p>
    </div>
    <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 max-w-2xl text-brand-ink/80">
      <li>Silverlake (77584)</li>
      <li>Shadow Creek Ranch (77584)</li>
      <li>Southern Trails (77584)</li>
      <li>Mary's Creek (77584)</li>
      <li>Sleepy Hollow (77581)</li>
      <li>Pearland West (77584)</li>
      <li>Old Pearland (77581)</li>
      <li>Friendswood adjacent</li>
    </ul>
    <p class="mt-6 text-brand-ink/80 max-w-2xl">Adjacent: Friendswood, League City, Manvel, south Houston / 288 corridor.</p>
  </section>

  <section class="bg-brand-ink text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 text-center max-w-2xl">
      <h2 class="font-heading text-2xl sm:text-3xl">Let's look at your floors</h2>
      <p class="mt-3 text-white/80 leading-relaxed">Free in-home consultation anywhere in Pearland. We come to you with full-size sample planks, measure your space, and email a written estimate within 48 hours.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href={BOOKING_URL} class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-6 py-3 text-white shadow-soft hover:opacity-90 transition" target="_blank" rel="nofollow noopener noreferrer">Book Free Consultation</a>
        <a href="tel:+18329305936" class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">Call (832) 930-5936</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
