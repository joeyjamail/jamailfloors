---
// [slug].astro - Dynamic product detail page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { PRODUCTS_DATA } from '../../data/products';
import { readdir } from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

// Export getStaticPaths for static generation
export function getStaticPaths() {
  return Object.keys(PRODUCTS_DATA).map((slug) => ({
    params: { slug },
  }));
}

// Get the product slug from the URL
const { slug } = Astro.params;

if (slug === 'alpine-frost') {
  return Astro.redirect('/products/avignon', 301);
}

if (slug === 'driftwood-haze') {
  return Astro.redirect('/products/modena', 301);
}

if (slug === 'riverstone-grey') {
  return Astro.redirect('/products/valencia', 301);
}

const product = slug ? PRODUCTS_DATA[slug as keyof typeof PRODUCTS_DATA] : undefined;

// If product doesn't exist, return 404
if (!product) {
  return Astro.redirect('/404');
}

// Keep product metadata concise enough for search results while preserving local intent.
const productSpeciesLabel = product.species.includes('Walnut') ? 'Walnut' : 'Oak';
const metaTitle = `${product.name} ${productSpeciesLabel} Flooring Houston | Jamail Hardwoods`;
const metaDescription = `${product.name} ${product.species} flooring in Houston with ${product.surface.toLowerCase()} texture, ${product.grade} grade, ${product.width} planks and ${product.finish} finish. Samples available.`;

// Tagline shown under the title (fallback if not provided)
const tagline = product.tagline ?? 'The feel of a modern Houston home.';

// Deterministic, slug-seeded recommendation list that prefers shared tags
function hashString(s: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}

function makeSeededRandom(seed: number) {
  let t = seed >>> 0;
  return function random() {
    // xorshift32
    t ^= t << 13; t ^= t >>> 17; t ^= t << 5;
    return ((t >>> 0) / 4294967296);
  };
}

function shuffle<T>(arr: T[], rnd: () => number): T[] {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(rnd() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const entries = Object.entries(PRODUCTS_DATA).filter(([k]) => k !== slug);
const productTags = new Set(product.tags);
const withSharedTags = entries.filter(([, p]) => p.tags.some((t) => productTags.has(t)));
const others = entries.filter((e) => !withSharedTags.includes(e));

const rnd = makeSeededRandom(hashString(String(slug)));
const recsPrimary = shuffle(withSharedTags, rnd);
const recsSecondary = shuffle(others, rnd);
const recommended = [...recsPrimary, ...recsSecondary].slice(0, 3).map(([s, p]) => ({
  slug: s,
  name: p.name,
  image: p.image,
  description: p.description,
}));

// Build gallery from public/images/Products/{slug} so all product photos render automatically.
async function getPublicProductGallery(productSlug: string, fallbackImage: string): Promise<string[]> {
  const projectRoot = path.resolve(fileURLToPath(new URL('../../..', import.meta.url)));
  const folderPath = path.join(projectRoot, 'public', 'images', 'Products', productSlug);

  try {
    const entries = await readdir(folderPath, { withFileTypes: true });
    const allowedExt = new Set(['.jpg', '.jpeg', '.png', '.webp', '.avif']);

    const images = entries
      .filter((entry) => entry.isFile())
      .map((entry) => entry.name)
      .filter((name) => allowedExt.has(path.extname(name).toLowerCase()))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }))
      .map((name) => `/images/Products/${productSlug}/${name}`);

    return images.length > 0 ? images : [fallbackImage];
  } catch {
    return [fallbackImage];
  }
}

const detected = await getPublicProductGallery(String(slug), product.image);
const gallery: string[] = (Array.isArray(product.gallery) && product.gallery.length > 0 ? product.gallery : detected);

function getSpecValue(
  specs: Record<string, string> | undefined,
  keys: string[],
  fallback = ''
): string {
  if (specs) {
    for (const key of keys) {
      const value = specs[key];
      if (typeof value === 'string' && value.trim().length > 0) {
        return value;
      }
    }
  }
  return fallback;
}

function normalizeBoardSize(value: string): string {
  return value.replace(/\s*x\s*/gi, ' x ').replace(/\s{2,}/g, ' ').trim();
}

const inferredBoardSize = [product.length, product.width, product.thickness]
  .filter((v) => typeof v === 'string' && v.trim().length > 0)
  .join(' x ');

const fullSpecs: Record<string, string> = {
  'Species': getSpecValue(product.specs, ['Species', 'Species:'], product.species || 'N/A'),
  'Construction': getSpecValue(product.specs, ['Construction', 'Construction:'], 'Engineered Wood'),
  'Installation Type': getSpecValue(product.specs, ['Installation Type', 'Installation Type:'], 'Staple; Nail; Glue; Float'),
  'Grade': getSpecValue(product.specs, ['Grade', 'Grade:'], product.grade || 'N/A'),
  'Surface': getSpecValue(product.specs, ['Surface', 'Surface:'], product.surface || 'N/A'),
  'Gloss Level': getSpecValue(product.specs, ['Gloss Level', 'Gloss Level:'], 'Low Gloss'),
  'Edges': getSpecValue(product.specs, ['Edges', 'Edges:'], 'Beveled'),
  'Board Size': normalizeBoardSize(getSpecValue(product.specs, ['Board Size', 'Board Size:'], inferredBoardSize || 'N/A')),
  'Wear Layer Thickness': getSpecValue(product.specs, ['Wear Layer Thickness', 'Wear Layer Thickness:', 'Wear Layer'], 'N/A'),
  'Pack Contents': getSpecValue(product.specs, ['Pack Contents', 'Pack Contents:'], 'N/A'),
  'Carton Coverage': getSpecValue(product.specs, ['Carton Coverage', 'Carton Coverage:', 'Coverage', 'Packing'], 'N/A'),
  'Finish': getSpecValue(product.specs, ['Finish', 'Finish:'], product.finish || 'N/A'),
  'Commercial Or Residential': getSpecValue(product.specs, ['Commercial Or Residential', 'Commercial Or Residential:'], 'Yes')
};

// Construct full URLs for Open Graph
const currentUrl = `https://jamailfloors.com/products/${slug}/`;
const ogImageUrl = new URL(gallery[0], 'https://jamailfloors.com').toString();
---

<Layout 
  title={metaTitle} 
  description={metaDescription}
  ogImage={ogImageUrl}
  ogUrl={currentUrl}
  ogType="product"
>
  <Header />

  <!-- Breadcrumbs -->
  <Breadcrumbs items={[{ href: '/', label: 'Home' }, { href: '/products', label: 'Products' }, { label: product.name }]} />

  <!-- Product Detail Hero -->
  <section class="relative overflow-hidden desktop-xl:py-2 fhd:py-4">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 qhd:px-8 uhd:px-10 pt-6 desktop-xl:pt-12 fhd:pt-16 pb-14 desktop-xl:pb-20 fhd:pb-24">

  <div class="grid md:grid-cols-2 gap-8 md:gap-10 desktop-xl:gap-12 fhd:gap-16 qhd:gap-20 items-start">
        <!-- Product Media -->
        <div class="reveal order-2 md:order-1">
          <div class="relative overflow-hidden rounded-2xl md:rounded-3xl shadow-soft">
            <img 
              id="main-image"
              src={gallery[0]} 
              alt={`${product.name} ${product.grade} grade ${product.species} hardwood flooring with ${product.surface} surface - ${product.width} wide planks installed in Houston home interior`}
              class="w-full aspect-4/3 object-cover"
              loading="eager"
              width="800"
              height="600"
            />
          </div>
          <!-- Thumbnails -->
          {gallery.length > 1 && (
          <div class="mt-4 grid grid-cols-3 phone-md:grid-cols-4 md:grid-cols-5 gap-2 desktop-xl:gap-3">
            {gallery.map((img, idx) => (
              <button
                type="button"
                class={`thumbnail-btn aspect-square rounded-xl overflow-hidden border-2 ${idx === 0 ? 'border-brand-brass' : 'border-transparent'} hover:border-brand-brass transition-colors shadow-soft focus:outline-none`}
                data-img={img}
                aria-label={`Show image ${idx + 1}`}>
                <img src={img} alt={`${product.name} hardwood flooring detail view ${idx + 1} - ${product.surface} texture and grain pattern`} class="w-full h-full object-cover group-hover:opacity-90" loading="lazy" width="150" height="150" />
              </button>
            ))}
          </div>
          )}
        </div>

        <!-- Product Info -->
        <div class="reveal order-1 md:order-2">
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.16em] text-brand-brass">Houston showroom sample available</p>
          <h1 class="font-heading text-3xl md:text-4xl desktop-xl:text-5xl fhd:text-6xl leading-tight" itemprop="name">{product.name}</h1>
          <p class="mt-2 text-brand-ink/60 italic" itemprop="slogan">{tagline}</p>
          <div class="mt-4 text-brand-ink/80 leading-relaxed text-lg desktop-xl:text-xl" itemprop="description">
            {product.description}
          </div>

          <dl class="mt-5 grid grid-cols-2 gap-3 text-sm">
            <div class="border-t border-brand-ink/10 pt-3">
              <dt class="text-xs uppercase tracking-wide text-brand-ink/50">Species</dt>
              <dd class="mt-1 font-semibold">{product.species}</dd>
            </div>
            <div class="border-t border-brand-ink/10 pt-3">
              <dt class="text-xs uppercase tracking-wide text-brand-ink/50">Width</dt>
              <dd class="mt-1 font-semibold">{product.width}</dd>
            </div>
            <div class="border-t border-brand-ink/10 pt-3">
              <dt class="text-xs uppercase tracking-wide text-brand-ink/50">Surface</dt>
              <dd class="mt-1 font-semibold">{product.surface}</dd>
            </div>
            <div class="border-t border-brand-ink/10 pt-3">
              <dt class="text-xs uppercase tracking-wide text-brand-ink/50">Finish</dt>
              <dd class="mt-1 font-semibold">{product.finish}</dd>
            </div>
          </dl>

          <!-- CTA Buttons -->
          <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
            <a href="/contact" class="inline-flex items-center justify-center rounded-xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:bg-brand-walnut transition">Request This Sample</a>
            <a href="https://jamail-hardwoods-leads.vercel.app/booking" target="_blank" rel="nofollow noopener noreferrer" class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition">Book Consultation</a>
          </div>

          <div class="mt-4 flex flex-wrap gap-2 text-xs text-brand-ink/65">
            <span class="border border-brand-ink/10 px-3 py-1.5">Free samples</span>
            <span class="border border-brand-ink/10 px-3 py-1.5">Houston installation</span>
            <span class="border border-brand-ink/10 px-3 py-1.5">Low-VOC finishes</span>
          </div>

          <!-- Specifications -->
          {fullSpecs && (
          <section class="mt-6 border-t border-brand-ink/10 pt-6" aria-labelledby="specs-heading">
            <h2 id="specs-heading" class="font-semibold text-lg mb-4">Product Specifications</h2>
            <dl class="grid grid-cols-1 sm:grid-cols-2 desktop-xl:grid-cols-3 gap-x-6 gap-y-3 desktop-xl:gap-y-4 text-sm">
              {Object.entries(fullSpecs).map(([key, value]) => (
                <div>
                  <dt class="text-brand-ink/60">{key}</dt>
                  <dd class="font-medium mt-1">{value}</dd>
                </div>
              ))}
            </dl>
          </section>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Tagline + Body Copy -->
  <article class="bg-white py-12 desktop-xl:py-16 fhd:py-20">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-2xl sm:text-3xl">{product.sectionTitle ?? tagline}</h2>
        {Array.isArray(product.body) && product.body.length > 0 ? (
          product.body.map((para) => <p class="mt-3 text-brand-ink/80 leading-relaxed">{para}</p>)
        ) : (
          <p class="mt-3 text-brand-ink/80 leading-relaxed">{product.description}</p>
        )}
      </div>
    </div>
  </article>

  <!-- You might also like -->
  <section class="bg-white py-12 desktop-xl:py-16 fhd:py-20" aria-labelledby="related-products">
    <div class="container mx-auto px-4 sm:px-6">
      <h2 id="related-products" class="font-heading text-2xl sm:text-3xl text-center mb-8">Related Products You Might Like</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 desktop-xl:grid-cols-4 fhd:grid-cols-5 gap-6 desktop-xl:gap-8 fhd:gap-10">
        {recommended.map((r) => (
          <a href={`/products/${r.slug}`} class="group block rounded-2xl overflow-hidden bg-white shadow-soft hover:shadow-md transition">
            <div class="aspect-4/3 overflow-hidden bg-brand-sand/30">
              <img src={r.image} alt={`${r.name} European oak hardwood flooring - premium quality wood floors for Houston homes`} class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform" loading="lazy" width="400" height="300" />
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-brand-ink group-hover:text-brand-brass transition">{r.name}</h3>
              <p class="text-sm text-brand-ink/60">{r.description}</p>
              <div class="mt-2 text-sm text-brand-brass">View Product →</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Callout CTA -->
  <section class="py-10 desktop-xl:py-16 fhd:py-20">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="rounded-2xl bg-brand-ink text-white p-6 sm:p-8 shadow-soft text-center">
        <h3 class="font-heading text-xl sm:text-2xl">See {product.name} in Your Home</h3>
        <p class="mt-2 text-white/80 text-sm">The best way to choose a floor is to see it in your own space, with your own lighting. Order a free, large-format sample today.</p>
        <div class="mt-4">
          <a href="/contact" class="inline-flex items-center justify-center rounded-xl bg-white text-brand-ink px-5 py-3 hover:bg-brand-sand transition shadow-soft">Get Your Free Sample</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose This Product -->
  <section class="bg-white py-16">
    <div class="container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-heading text-2xl sm:text-3xl text-center mb-8">Why Choose {product.name}?</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="reveal rounded-2xl bg-brand-sand/40 p-6">
            <h3 class="font-semibold mb-2">Superior Stability</h3>
            <p class="text-sm text-brand-ink/70">Engineered construction provides excellent dimensional stability, perfect for Houston's climate.</p>
          </div>
          <div class="reveal rounded-2xl bg-brand-sand/40 p-6">
            <h3 class="font-semibold mb-2">Professional Installation</h3>
            <p class="text-sm text-brand-ink/70">Our certified installers ensure a flawless finish with dust-controlled processes.</p>
          </div>
          <div class="reveal rounded-2xl bg-brand-sand/40 p-6">
            <h3 class="font-semibold mb-2">Low VOC Finish</h3>
            <p class="text-sm text-brand-ink/70">Healthy, eco-friendly UV oil finish that's safe for your family and the environment.</p>
          </div>
          <div class="reveal rounded-2xl bg-brand-sand/40 p-6">
            <h3 class="font-semibold mb-2">Timeless Beauty</h3>
            <p class="text-sm text-brand-ink/70">European White Oak's natural elegance enhances any design style and increases home value.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <section class="container mx-auto px-4 sm:px-6 py-16">
    <h2 class="font-heading text-2xl sm:text-3xl text-center mb-10">Explore Similar Styles</h2>
    <div class="flex justify-center gap-3 flex-wrap">
      {product.tags.map((tag: string) => (
        <a href={`/products?filter=${tag}`}
           class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-2 text-white shadow-soft hover:opacity-90 transition">
          View All {tag.charAt(0).toUpperCase() + tag.slice(1)} Tones
        </a>
      ))}
      <a href="/products"
         class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-2 text-brand-ink shadow-soft hover:bg-brand-sand transition">
        Browse All Products
      </a>
    </div>
  </section>

  <!-- Enhanced Product Schema JSON-LD for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": product.name,
    "description": metaDescription,
    "image": gallery.map(img => `https://jamailfloors.com${img}`),
    "brand": {
      "@type": "Brand",
      "name": "Jamail Hardwoods"
    },
    "sku": slug,
    "mpn": slug,
    "offers": {
      "@type": "Offer",
      "availability": "https://schema.org/InStock",
      "url": `https://jamailfloors.com/products/${slug}`,
      "itemCondition": "https://schema.org/NewCondition",
      "seller": {
        "@type": "LocalBusiness",
        "name": "Jamail Hardwoods",
        "url": "https://jamailfloors.com",
        "areaServed": {
          "@type": "City",
          "name": "Houston",
          "containedInPlace": {
            "@type": "State",
            "name": "Texas"
          }
        }
      }
    },
    "additionalProperty": [
      {
        "@type": "PropertyValue",
        "name": "Species",
        "value": product.species
      },
      {
        "@type": "PropertyValue",
        "name": "Grade",
        "value": product.grade
      },
      {
        "@type": "PropertyValue",
        "name": "Surface",
        "value": product.surface
      },
      {
        "@type": "PropertyValue",
        "name": "Width",
        "value": product.width
      },
      {
        "@type": "PropertyValue",
        "name": "Thickness",
        "value": product.thickness
      },
      {
        "@type": "PropertyValue",
        "name": "Finish",
        "value": product.finish
      }
    ],
    "category": "Hardwood Flooring",
    "material": product.species
  })}></script>

  <!-- BreadcrumbList Schema for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://jamailfloors.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Products",
        "item": "https://jamailfloors.com/products"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": product.name,
        "item": `https://jamailfloors.com/products/${slug}`
      }
    ]
  })}></script>

  <!-- Gallery scripting: swap main image on thumbnail click and toggle active border -->
  <script type="module">
    const main = document.getElementById('main-image');
    const buttons = Array.from(document.querySelectorAll('.thumbnail-btn'));
    function activate(btn) {
      buttons.forEach(b => b.classList.remove('border-brand-brass'));
      buttons.forEach(b => b.classList.add('border-transparent'));
      btn.classList.remove('border-transparent');
      btn.classList.add('border-brand-brass');
    }
    buttons.forEach(btn => btn.addEventListener('click', (e) => {
      e.preventDefault();
      const src = btn.getAttribute('data-img');
      if (!src || !main) return;
      main.setAttribute('src', src);
      activate(btn);
    }));
  </script>

  <Footer />
</Layout>
