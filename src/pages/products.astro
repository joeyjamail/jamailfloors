---
// products.astro - Products catalog page
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Hardwood Flooring Products in Houston | Jamail Hardwoods Collections"
  description="Explore our complete collection of European White Oak hardwood flooring. View our light, warm, and neutral-toned products, perfect for any Houston home. Get free samples."
>
  <Header />


  <!-- Hero -->
  <section class="relative overflow-hidden bg-brand-ivory py-16">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-sand/60 via-brand-ivory to-brand-ivory pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 text-center relative">
      <div class="reveal max-w-3xl mx-auto">
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight text-brand-ink">Our European Oak Collections</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">
          Explore our curated collections of wide-plank European White Oak. Each product is selected for its timeless beauty, superior stability, and healthy, low-VOC finish. Find the perfect foundation for your Houston home.
        </p>
        <div class="mt-6">
          <a href="#" data-open-samples
             class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition">
            Build Your Free Sample Box
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Filters -->
  <section class="container mx-auto px-4 sm:px-6 pb-10 -mt-1 relative z-10">
    <div class="mx-auto max-w-6xl rounded-3xl border border-black/5 bg-white/90 p-4 shadow-glass backdrop-blur-sm sm:p-6">
      <div class="mb-4 flex flex-col gap-3 border-b border-black/5 pb-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-brand-ink/50">Find The Right Floor Faster</p>
          <p class="text-sm text-brand-ink/75">Use style + dimensions to narrow your shortlist.</p>
        </div>
        <div class="flex items-center gap-2 sm:gap-3">
          <span id="filter-results-count" class="inline-flex items-center rounded-full bg-brand-sand/70 px-3 py-1 text-xs font-semibold text-brand-ink/75">Showing all products</span>
          <button id="clear-all-filters" type="button" class="inline-flex items-center justify-center rounded-full border border-brand-ink/10 px-3 py-1.5 text-xs font-semibold text-brand-ink/75 hover:bg-brand-sand/40 transition">Reset Filters</button>
        </div>
      </div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <label class="filter-select-block">
          <span class="filter-label">Style</span>
          <select id="style-filter-select" class="filter-select">
            <option value="all">All Products</option>
            <option value="light">Light & Airy</option>
            <option value="warm">Warm & Earthy</option>
            <option value="modern">Modern & Neutral</option>
            <option value="dark">Dark & Moody</option>
          </select>
        </label>

        <label class="filter-select-block">
          <span class="filter-label">Width</span>
          <select id="width-filter-select" class="filter-select">
            <option value="all">All Widths</option>
          </select>
        </label>

        <label class="filter-select-block">
          <span class="filter-label">Thickness</span>
          <select id="thickness-filter-select" class="filter-select">
            <option value="all">All Thicknesses</option>
          </select>
        </label>

        <label class="filter-select-block">
          <span class="filter-label">Wear Layer</span>
          <select id="wear-filter-select" class="filter-select">
            <option value="all">All Wear Layers</option>
          </select>
        </label>
      </div>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="container mx-auto px-4 sm:px-6 pb-16">
    <div id="product-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Product cards will be injected here -->
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container mx-auto px-4 sm:px-6 py-16">
    <div class="reveal rounded-3xl bg-brand-moss p-6 sm:p-8 md:p-12 text-center text-white shadow-soft">
      <h2 class="font-heading text-2xl sm:text-3xl">Can't Decide? We Can Help.</h2>
      <p class="mt-2 mx-auto max-w-2xl opacity-90 leading-relaxed">Our design experts can help you choose the perfect tone and texture for your space. Schedule a free consultation at our Houston showroom.</p>
      <div class="mt-6">
        <a href="/contact" class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-brand-coal shadow-soft hover:opacity-90 transition">
          Book a Free Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- Free Samples Modal -->
  <!-- Backdrop -->
  <div id="samples-backdrop" class="fixed inset-0 z-[200] hidden bg-black/50 backdrop-blur-sm"></div>

  <!-- Modal Dialog -->
  <div id="samples-modal" role="dialog" aria-modal="true" aria-labelledby="samples-title"
       class="fixed inset-0 z-[210] hidden grid place-items-center p-4">
    <div class="w-full max-w-5xl rounded-3xl bg-white shadow-glass overflow-hidden flex flex-col max-h-[90vh]">

      <!-- Header -->
      <div class="flex flex-shrink-0 items-center justify-between border-b border-black/5 px-6 py-4">
        <div>
          <h2 id="samples-title" class="font-heading text-xl sm:text-2xl">Build Your Free Sample Box</h2>
          <p class="text-sm text-brand-ink/70">Choose your samples, then confirm shipping details.</p>
        </div>
        <button type="button" id="samples-close"
          class="inline-flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full hover:bg-black/5"
          aria-label="Close">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor"><path stroke-width="1.7" d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>

      <!-- Steps -->
      <div class="flex flex-shrink-0 flex-wrap items-center gap-x-3 gap-y-2 border-b border-black/5 px-6 py-3 text-sm">
        <div class="flex items-center gap-2">
          <span class="step-dot size-6 grid place-items-center rounded-full bg-brand-brass text-white">1</span>
          <span class="font-medium hidden sm:inline">Select Samples</span>
        </div>
        <span class="opacity-40">—</span>
        <div class="flex items-center gap-2">
          <span class="step-dot size-6 grid place-items-center rounded-full bg-brand-sand text-brand-coal">2</span>
          <span class="font-medium hidden sm:inline">Shipping Details</span>
        </div>
        <div class="ml-auto text-xs text-brand-ink/60">
          <span id="selected-count">0</span> selected · up to <span id="max-allowed">6</span>
        </div>
      </div>

      <!-- Step 1: Selector -->
      <div id="step-1" class="overflow-y-auto px-6 pb-6">
        <!-- Tabs & Pagination -->
        <div class="flex items-center justify-between">
          <div id="samples-tabs" role="tablist" class="inline-flex rounded-full bg-brand-sand/60 p-1 shadow-soft">
            <button role="tab" data-cat="hardwood" aria-selected="true" disabled
              class="px-4 py-2 text-sm rounded-full data-[active=true]:bg-white data-[active=true]:shadow-soft data-[active=true]:text-brand-coal">
              Hardwood
            </button>
          </div>
          <div class="flex items-center gap-2">
            <button id="samples-prev" aria-label="Previous" class="size-9 grid place-items-center rounded-full bg-brand-sand/70 shadow-soft hover:bg-white transition disabled:opacity-40 disabled:cursor-not-allowed">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor"><path stroke-width="2" d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button id="samples-next" aria-label="Next" class="size-9 grid place-items-center rounded-full bg-brand-sand/70 shadow-soft hover:bg-white transition disabled:opacity-40 disabled:cursor-not-allowed">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor"><path stroke-width="2" d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>
        </div>

        <!-- Product Grid -->
        <div id="samples-grid" class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>

        <!-- Selection Tray -->
        <div id="selection-tray" class="mt-6 hidden rounded-2xl bg-brand-sand/50 p-4">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <!-- Left side: Chips (and clear button on desktop) -->
            <div class="flex-grow flex flex-col items-center sm:items-start gap-3">
              <div id="selection-chips" class="flex flex-wrap justify-center sm:justify-start items-center gap-2"></div>
              <button id="clear-all" class="sm:hidden text-sm underline text-brand-ink/70 hover:text-brand-ink">Clear all</button>
            </div>
            <!-- Right side: Buttons -->
            <div class="w-full sm:w-auto flex-shrink-0 flex items-center gap-4">
              <button id="clear-all-mobile" class="hidden sm:inline text-sm underline text-brand-ink/70 hover:text-brand-ink">Clear all</button>
              <button id="to-step-2" class="w-full sm:w-auto inline-flex items-center justify-center rounded-2xl bg-brand-brass px-4 py-2 text-white shadow-soft disabled:opacity-40 disabled:cursor-not-allowed">Continue</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Form -->
      <div id="step-2" class="hidden overflow-y-auto px-6 pb-6">
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Review -->
          <div>
            <h3 class="font-heading text-xl">Your Selection</h3>
            <p class="mt-1 text-sm text-brand-ink/70">We'll include large, labeled planks when available.</p>
            <ul id="review-list" class="mt-4 space-y-2 text-sm"></ul>
            <button id="back-to-step-1" class="mt-4 inline-flex items-center text-sm underline text-brand-ink/70 hover:text-brand-ink">
              ← Edit selection
            </button>
          </div>

          <!-- Form -->
          <form id="samples-form" class="grid gap-3" novalidate>
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="block text-sm">
                <span>Full Name</span>
                <input required name="name" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
              </label>
              <label class="block text-sm">
                <span>Email</span>
                <input required type="email" name="email" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
              </label>
            </div>
            <div class="grid sm:grid-cols-2 gap-3">
              <label class="block text-sm">
                <span>Phone</span>
                <input required type="tel" name="phone" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
              </label>
              <label class="block text-sm">
                <span>ZIP</span>
                <input required name="zip" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak">
              </label>
            </div>
            <label class="block text-sm">
              <span>Notes (optional)</span>
              <textarea name="notes" rows="4" class="mt-1 w-full rounded-xl border border-black/10 bg-brand-sand/40 px-3 py-2 outline-none focus:ring-2 focus:ring-brand-oak" placeholder="Timeline, square footage, preferred tones…"></textarea>
            </label>
            <!-- Honeypot for bots -->
            <div class="hidden">
              <label>Company <input type="text" name="company" tabindex="-1" autocomplete="off"></label>
            </div>
            <div id="samples-success" class="hidden rounded-xl bg-green-50 border border-green-300 text-green-800 text-sm px-4 py-3"></div>

            <button type="submit"
              class="mt-2 inline-flex items-center justify-center rounded-2xl bg-brand-moss px-5 py-3 text-white shadow-soft hover:opacity-90 transition">
              Request Free Samples
            </button>
            <p class="text-xs text-brand-ink/60">By submitting, you agree to be contacted about your project.</p>
          </form>
        </div>
      </div>

    </div>
  </div>

  <!-- Breadcrumbs JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://jamailfloors.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Products",
        "item": "https://jamailfloors.com/products"
      }
    ]
  })}></script>

  <Footer />
</Layout>
