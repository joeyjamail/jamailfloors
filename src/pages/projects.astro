---
// projects.astro - Project Gallery
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const BOOKING_URL = 'https://jamail-hardwoods-leads.vercel.app/booking';

// Project gallery - swap image paths and captions with real project photos as they're added.
// Image naming convention: /images/projects/[neighborhood]-[descriptor]-[##].jpg
const projects = [
  {
    neighborhood: 'River Oaks',
    slug: 'river-oaks',
    style: 'Traditional Renovation',
    sqft: '3,200 sq ft',
    finish: 'Natural matte white oak',
    image: '/images/projects/river-oaks-traditional-01.jpg',
    caption: 'Full main-floor replacement in a 1930s River Oaks home — wide plank European white oak with hand-rubbed matte oil finish.'
  },
  {
    neighborhood: 'Memorial',
    slug: 'memorial',
    style: 'Modern New Build',
    sqft: '4,500 sq ft',
    finish: 'Light fumed oak',
    image: '/images/projects/memorial-modern-01.jpg',
    caption: 'New construction in Memorial — 9-inch wide plank European white oak with a light fumed finish for a clean contemporary look.'
  },
  {
    neighborhood: 'The Heights',
    slug: 'heights',
    style: 'Bungalow Restoration',
    sqft: '1,800 sq ft',
    finish: 'Warm honey oak',
    image: '/images/projects/heights-bungalow-01.jpg',
    caption: 'Heights bungalow renovation — wide plank European white oak with warm honey-toned finish to complement the original woodwork.'
  },
  {
    neighborhood: 'The Woodlands',
    slug: 'the-woodlands',
    style: 'Custom Home',
    sqft: '5,800 sq ft',
    finish: 'Smoked oak',
    image: '/images/projects/woodlands-custom-01.jpg',
    caption: 'Custom home in The Woodlands — smoked European white oak across the main level with a soft brushed texture.'
  },
  {
    neighborhood: 'West University',
    slug: 'west-university',
    style: 'Whole-Home Renovation',
    sqft: '2,900 sq ft',
    finish: 'Natural white oak',
    image: '/images/projects/west-u-renovation-01.jpg',
    caption: 'West U whole-home refresh — natural finish wide plank European white oak with consistent grade across the main floor and upstairs.'
  },
  {
    neighborhood: 'Bellaire',
    slug: 'bellaire',
    style: 'Family Home Refresh',
    sqft: '2,400 sq ft',
    finish: 'Light grey-washed oak',
    image: '/images/projects/bellaire-family-01.jpg',
    caption: 'Bellaire family home — light grey-washed European white oak for a bright, modern feel that hides everyday wear.'
  },
  {
    neighborhood: 'Katy',
    slug: 'katy',
    style: 'New Construction',
    sqft: '3,800 sq ft',
    finish: 'Honey oak',
    image: '/images/projects/katy-newbuild-01.jpg',
    caption: 'Katy new build — wide plank European white oak with a warm honey finish, installed before move-in.'
  },
  {
    neighborhood: 'Sugar Land',
    slug: 'sugar-land',
    style: 'Modern Renovation',
    sqft: '3,100 sq ft',
    finish: 'Light natural oak',
    image: '/images/projects/sugar-land-modern-01.jpg',
    caption: 'Sugar Land modern renovation — light natural European white oak with a clean matte finish throughout the main floor.'
  },
  {
    neighborhood: 'Tanglewood',
    slug: 'tanglewood',
    style: 'Traditional Refresh',
    sqft: '2,700 sq ft',
    finish: 'Rich walnut-tone oak',
    image: '/images/projects/tanglewood-traditional-01.jpg',
    caption: 'Tanglewood traditional refresh — rich walnut-toned European white oak that elevates the home\'s classic architecture.'
  },
];
---

<Layout
  title="Houston Hardwood Flooring Projects | Jamail Hardwoods Gallery"
  description="Real Houston homes with European white oak floors by Jamail Hardwoods. Project gallery organized by neighborhood — River Oaks, Memorial, Heights, The Woodlands, Katy & more."
>
  <Header />

  <!-- JSON-LD: ItemList for the project gallery -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Houston Hardwood Flooring Projects",
    "description": "Project gallery of European white oak flooring installations across Houston neighborhoods",
    "itemListElement": projects.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "CreativeWork",
        "name": `${p.neighborhood} — ${p.style}`,
        "description": p.caption,
        "image": `https://jamailfloors.com${p.image}`,
        "url": `https://jamailfloors.com/houston/${p.slug}`
      }
    }))
  })}></script>

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-linear-to-b from-brand-sand/60 via-brand-ivory to-white pointer-events-none"></div>
    <div class="container mx-auto px-4 sm:px-6 pt-16 pb-14 text-center">
      <div class="reveal max-w-3xl mx-auto">
        <p class="text-xs uppercase tracking-[0.2em] text-brand-brass font-semibold mb-3">Project Gallery</p>
        <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl leading-tight">Real Houston Homes. Real Houston Floors.</h1>
        <p class="mt-4 text-brand-ink/80 leading-relaxed">
          Browse recent European white oak installations across Houston — from River Oaks renovations and Memorial new builds to Heights bungalow refreshes. Every project is wide-plank European white oak with finishes selected for the home.
        </p>
        <div class="mt-6">
          <a href={BOOKING_URL}
             class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition"
             target="_blank" rel="nofollow noopener noreferrer">
            Book Your Free Consultation
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Project Grid -->
  <section class="container mx-auto px-4 sm:px-6 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((p) => (
        <a href={`/houston/${p.slug}`} class="group block rounded-2xl bg-white shadow-soft overflow-hidden hover:shadow-lg transition">
          <div class="aspect-[4/3] bg-brand-sand/40 overflow-hidden">
            <img src={p.image} alt={`${p.neighborhood} hardwood flooring project — ${p.style}, ${p.finish}`}
                 loading="lazy"
                 class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <span class="text-xs uppercase tracking-[0.15em] text-brand-brass font-semibold">{p.neighborhood}</span>
              <span class="text-xs text-brand-ink/60">{p.sqft}</span>
            </div>
            <h3 class="font-heading text-xl text-brand-ink leading-tight mb-1">{p.style}</h3>
            <p class="text-sm text-brand-ink/70 mb-3">{p.finish}</p>
            <p class="text-sm text-brand-ink/80 leading-relaxed">{p.caption}</p>
            <p class="mt-3 text-xs text-brand-brass font-semibold uppercase tracking-[0.1em]">
              View {p.neighborhood} services →
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Visit Showroom CTA -->
  <section class="bg-brand-ivory py-16">
    <div class="container mx-auto px-4 sm:px-6 max-w-3xl text-center">
      <h2 class="font-heading text-2xl sm:text-3xl">See It In Person</h2>
      <p class="mt-2 text-brand-ink/80 leading-relaxed">
        Photos help, but seeing wide plank European white oak in your own light is what makes the decision easy. Visit our Houston showroom on Colquitt Street, or have a free sample box shipped to your home.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/contact"
           class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:opacity-90 transition">
          Visit the Showroom
        </a>
        <a href={BOOKING_URL}
           class="inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-brand-ink shadow-soft hover:bg-brand-sand transition"
           target="_blank" rel="nofollow noopener noreferrer">
          Free Sample Box
        </a>
      </div>
    </div>
  </section>

  <!-- Browse Neighborhoods -->
  <section class="container mx-auto px-4 sm:px-6 py-12">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading text-2xl sm:text-3xl mb-3">Browse Houston Neighborhoods We Serve</h2>
      <p class="text-brand-ink/70 mb-6">Local installation across the metro — pick your neighborhood for project details and timelines.</p>
      <div class="flex flex-wrap justify-center gap-2">
        <a href="/houston/river-oaks" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">River Oaks</a>
        <a href="/houston/memorial" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">Memorial</a>
        <a href="/houston/heights" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">The Heights</a>
        <a href="/houston/the-woodlands" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">The Woodlands</a>
        <a href="/houston/west-university" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">West University</a>
        <a href="/houston/bellaire" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">Bellaire</a>
        <a href="/houston/katy" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">Katy</a>
        <a href="/houston/sugar-land" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">Sugar Land</a>
        <a href="/houston/tanglewood" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">Tanglewood</a>
        <a href="/houston/spring-branch" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">Spring Branch</a>
        <a href="/houston/pearland" class="px-4 py-2 rounded-full bg-white text-sm text-brand-ink shadow-soft hover:bg-brand-sand transition">Pearland</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
