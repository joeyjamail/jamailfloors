---
// Header component for Jamail Hardwoods
---

<!-- USP / Trust Bar -->
<div class="bg-brand-coal text-white/90 text-xs">
  <div class="container mx-auto px-4 py-2">
    <div class="hidden sm:flex items-center justify-center gap-x-6">
        <div class="inline-flex items-center gap-2">
          <img src="/images/Google_Favicon_2025.svg" alt="Google" class="h-4 w-4" decoding="async" fetchpriority="high" width="16" height="16">
          <span class="text-yellow-400">★★★★★</span>
          <span>4.9 on Google</span>
        </div>
        <span class="opacity-30">|</span>
        <div class="inline-flex items-center gap-2">
          <svg class="h-4 w-4 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-width="1.7" d="M3 7h11v8H3zM14 9h4l3 3v3h-7zM6 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
          </svg>
          <span>Free Sample Box</span>
        </div>
        <span class="opacity-30">|</span>
        <div class="inline-flex items-center gap-2">
          <svg class="h-4 w-4 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-width="1.7" d="M12 3l7 4v5c0 5-3.5 8.5-7 9-3.5-.5-7-4-7-9V7l7-4z"/>
          </svg>
          <span>Licensed & Insured Installers</span>
        </div>
      </div>
    <div class="sm:hidden flex items-center justify-center gap-2 whitespace-nowrap">
      <img src="/images/Google_Favicon_2025.svg" alt="Google" class="h-4 w-4" decoding="async" width="16" height="16">
      <span class="text-yellow-400">★★★★★</span>
      <span>4.9 on Google</span>
      <span class="opacity-30">|</span>
      <span>Free samples</span>
    </div>
  </div>
</div>

<!-- Header -->
<header class="sticky top-0 z-50 backdrop-blur bg-white/70 border-b border-black/5">
  <div class="container mx-auto flex items-center justify-between py-3 md:px-0 lg:py-2 desktop-xl:py-4 fhd:py-5 px-4 phone-xs:px-3 sm:px-0 qhd:px-8 uhd:px-10">
    <a href="/" class="flex items-center gap-2 lg:pl-8 md:pl-10">
      <img src="/images/jamail hardwoods logo.png" alt="Jamail Hardwoods" class="h-12 md:h-8 desktop-xl:h-14 fhd:h-16 w-auto" loading="eager" decoding="async">
    </a>
    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-4 desktop-xl:gap-6 fhd:gap-8">
      <nav class="flex items-center gap-6 desktop-xl:gap-8 text-sm desktop-xl:text-[0.95rem] fhd:text-base">
        <a class="hover:underline" href="/">Home</a>
        <a class="hover:underline" href="/products">Products</a>
        <a class="hover:underline" href="/services">Services</a>
        <a class="hover:underline" href="/installation">Installation</a>
        <a class="hover:underline" href="/faq">FAQ</a>
        <a class="hover:underline" href="/about">About</a>
        <a class="hover:underline" href="/contact">Contact</a>
      </nav>
      <a href="https://jamail-hardwoods-leads.vercel.app/booking"
         class="ml-4 inline-flex items-center justify-center rounded-2xl bg-brand-brass px-4 desktop-xl:px-5 fhd:px-6 py-2 fhd:py-3 text-white shadow-soft hover:opacity-90 transition"
         rel="nofollow noopener noreferrer" target="_blank">Book a Consultation</a>
    </div>
  <!-- Mobile Menu Button (visible up to lg) -->
  <div class="lg:hidden">
      <button id="mobile-menu-btn" type="button" class="p-2 rounded-md text-brand-ink hover:bg-brand-sand" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
        <!-- Hamburger Icon (wider) -->
        <svg class="h-6 w-7 md:h-7 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path class="stroke-2 md:stroke-3 [stroke-linecap:round] [stroke-linejoin:round]" d="M3 6h18M3 12h18M3 18h18" />
        </svg>
        <!-- Close Icon (wider to match) -->
        <svg class="hidden h-6 w-7 md:h-7 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path class="stroke-2 md:stroke-3 [stroke-linecap:round] [stroke-linejoin:round]" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay (visible up to lg) -->
<div id="mobile-overlay" class="hidden fixed inset-0 bg-linear-to-b from-black/60 to-black/80 backdrop-blur-md z-[80] transition-opacity duration-300 lg:hidden"></div>

<!-- Mobile Menu (visible up to lg) -->
<nav id="mobile-menu" class="hidden fixed top-0 left-0 right-0 bottom-0 bg-linear-to-br from-brand-ivory via-white to-brand-sand z-[90] overflow-y-auto lg:hidden">
  <div class="min-h-screen p-8">
    <!-- Header with Close Button -->
    <div class="flex items-center justify-between mb-12">
      <div class="flex items-center gap-3">
        <div class="w-1 h-8 bg-brand-brass rounded-full"></div>
        <span class="font-heading text-2xl text-brand-coal">Menu</span>
      </div>
      <button id="mobile-menu-close" type="button" class="p-3 rounded-full bg-brand-coal/5 hover:bg-brand-coal/10 transition-all duration-300 hover:rotate-90" aria-label="Close menu">
        <svg class="h-7 w-7 text-brand-coal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- Menu Links with Stagger Animation -->
    <div class="divide-y divide-brand-coal/10 border-y border-brand-coal/10">
      <a href="/" class="group flex items-center justify-between py-4 text-xl font-semibold text-brand-coal hover:text-brand-brass transition-colors">
        Home
        <span class="text-brand-brass opacity-60">→</span>
      </a>
      <a href="/products" class="group flex items-center justify-between py-4 text-xl font-semibold text-brand-coal hover:text-brand-brass transition-colors">
        Products
        <span class="text-brand-brass opacity-60">→</span>
      </a>
      <a href="/services" class="group flex items-center justify-between py-4 text-xl font-semibold text-brand-coal hover:text-brand-brass transition-colors">
        Services
        <span class="text-brand-brass opacity-60">→</span>
      </a>
      <a href="/installation" class="group flex items-center justify-between py-4 text-xl font-semibold text-brand-coal hover:text-brand-brass transition-colors">
        Installation
        <span class="text-brand-brass opacity-60">→</span>
      </a>
      <a href="/faq" class="group flex items-center justify-between py-4 text-xl font-semibold text-brand-coal hover:text-brand-brass transition-colors">
        FAQ
        <span class="text-brand-brass opacity-60">→</span>
      </a>
      <a href="/about" class="group flex items-center justify-between py-4 text-xl font-semibold text-brand-coal hover:text-brand-brass transition-colors">
        About
        <span class="text-brand-brass opacity-60">→</span>
      </a>
      <a href="/contact" class="group flex items-center justify-between py-4 text-xl font-semibold text-brand-coal hover:text-brand-brass transition-colors">
        Contact
        <span class="text-brand-brass opacity-60">→</span>
      </a>
    </div>
    
    <!-- CTA Button with Glow Effect -->
    <div class="mt-10">
    <a href="https://jamail-hardwoods-leads.vercel.app/booking" 
      class="block text-center rounded-xl bg-brand-brass px-8 py-4 text-white text-lg font-bold shadow-soft hover:bg-brand-walnut transition-colors" 
         target="_blank" 
         rel="nofollow noopener noreferrer">
        Book a Consultation
      </a>
    </div>
    
    <!-- Decorative Elements -->
    <div class="mt-12 pt-8 border-t border-brand-coal/10">
      <p class="text-center text-sm text-brand-coal/60">Premium European White Oak</p>
      <p class="text-center text-xs text-brand-coal/40 mt-1">Houston's Finest Hardwood Flooring</p>
    </div>
  </div>
</nav>

<!-- Mobile Conversion Bar -->
<div class="fixed inset-x-0 bottom-0 z-[70] border-t border-black/10 bg-white/95 px-3 py-2 shadow-[0_-10px_30px_rgba(0,0,0,.08)] backdrop-blur lg:hidden">
  <div class="grid grid-cols-3 gap-2 text-sm font-semibold">
    <a href="tel:+18329305936" class="rounded-xl border border-black/10 px-2 py-3 text-center text-brand-ink">Call</a>
    <a href="/contact" class="rounded-xl border border-black/10 px-2 py-3 text-center text-brand-ink">Samples</a>
    <a href="https://jamail-hardwoods-leads.vercel.app/booking" target="_blank" rel="nofollow noopener noreferrer" class="rounded-xl bg-brand-brass px-2 py-3 text-center text-white">Book</a>
  </div>
</div>

