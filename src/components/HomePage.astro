---
// HomePage.astro - Main content for the home page
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Hardwood Flooring Houston | European White Oak | Jamail Hardwoods"
  description="Shop premium European white oak flooring in Houston with wide planks, low-VOC finishes, expert installation, showroom guidance, and free samples."
  preloadImage="/images/Products/sandpoint-ivory/sandpoint-ivory-oak-flooring-in-houston-interior.jpg"
>
  <Header />

  <!-- Hero -->
  <section class="relative overflow-hidden bg-brand-ivory desktop-xl:py-2 fhd:py-4">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-sand/70 via-brand-ivory to-white pointer-events-none"></div>
  <div class="container mx-auto grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-10 desktop-xl:gap-12 fhd:gap-16 qhd:gap-20 items-center pt-8 md:pt-14 desktop-xl:pt-16 fhd:pt-20 pb-10 md:pb-16 desktop-xl:pb-20 fhd:pb-24 px-4 qhd:px-6 uhd:px-8">
        <div class="reveal md:text-center lg:text-left">
          <div class="mb-6 inline-flex md:mx-auto lg:mx-0 items-center gap-3 rounded-full bg-white/80 px-5 py-2 text-sm shadow-soft backdrop-blur">
            <img src="/images/google review.png" alt="Google Reviews" class="h-5 w-5 md:h-6 md:w-14 phone-md:w-12" loading="lazy" decoding="async">
            <div class="flex items-center gap-0.5 text-yellow-500">
              <span class="text-base">★</span>
              <span class="text-base">★</span>
              <span class="text-base">★</span>
              <span class="text-base">★</span>
              <span class="text-base">★</span>
            </div>
            <span class="text-brand-ink/80 font-medium">4.9/5 from 120+ Houston installs</span>
          </div>

          <h1 class="font-heading text-4xl md:text-4xl desktop-xl:text-6xl fhd:text-7xl qhd:text-7xl uhd:text-8xl leading-tight text-brand-ink">
            Hardwood Flooring in Houston – Premium European White Oak Floors
          </h1>
<div class="mt-6 text-brand-ink/80 max-w-xl">

  <p class="text-lg leading-relaxed">
    Luxury <strong>European white oak flooring</strong> installed by Houston specialists.
    Low-VOC finishes, designer collections, and fast installation.
  </p>

  <ul class="mt-4 space-y-2 text-base">
    <li class="flex items-center gap-2">
      <span class="text-green-600">✓</span> Expert installation
    </li>
    <li class="flex items-center gap-2">
      <span class="text-green-600">✓</span> Low-VOC finishes safe for families
    </li>
    <li class="flex items-center gap-2">
      <span class="text-green-600">✓</span> Designer-grade wide plank floors
    </li>
  </ul>

</div>
          <div class="mt-6 flex flex-wrap gap-3 desktop-xl:gap-4 fhd:gap-5 md:justify-center lg:justify-start">
            <a href="https://jamail-hardwoods-leads.vercel.app/booking" rel="nofollow noopener noreferrer"
               class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 py-3 text-white shadow-soft hover:bg-brand-oak transition" target="_blank">Book a Consultation</a>
            <!-- Added data-open-samples -->
            <a href="/samples" data-open-samples
               class="inline-flex items-center justify-center rounded-2xl bg-brand-sand px-5 py-3 text-brand-coal shadow-soft hover:bg-brand-clay transition">Get Free Samples</a>
          </div>

          <!-- Trust Points (adaptive for desktop vs mobile) -->

        </div>
        <div class="reveal md:max-w-3xl md:mx-auto lg:max-w-none lg:mx-0">
          <img src="/images/Products/sandpoint-ivory/sandpoint-ivory-oak-flooring-in-houston-interior.jpg" alt="Bright living room with light-colored European White Oak hardwood flooring" class="aspect-[4/3] w-full h-full object-cover rounded-3xl shadow-glass" loading="eager" fetchpriority="high" decoding="async" width="1200" height="900">
        </div>
      </div>
    </section>

  <!-- Local Relevance Section -->
<section id="houston-installation" class="bg-white py-10 sm:py-12 desktop-xl:py-16">
  <div class="container mx-auto px-4">
    <div class="reveal rounded-3xl bg-brand-sand/40 p-6 sm:p-8 shadow-soft">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-center">
        <div class="lg:col-span-8">
          <h2 class="font-heading text-2xl sm:text-3xl text-brand-ink">
            Hardwood Flooring Installation in Houston
          </h2>
          <p class="mt-3 text-sm sm:text-base text-brand-ink/80 leading-relaxed">
            European white oak installs with moisture testing, dust control, and low-VOC finishes—trusted by Houston homeowners, builders, and designers.
          </p>

          <div class="mt-4 flex flex-wrap gap-2 text-xs sm:text-sm">
            <span class="rounded-full bg-white px-3 py-1 shadow-soft text-brand-ink/75">Houston</span>
            <span class="rounded-full bg-white px-3 py-1 shadow-soft text-brand-ink/75">Katy</span>
            <span class="rounded-full bg-white px-3 py-1 shadow-soft text-brand-ink/75">Sugar Land</span>
            <span class="rounded-full bg-white px-3 py-1 shadow-soft text-brand-ink/75">The Woodlands</span>
            <span class="rounded-full bg-white px-3 py-1 shadow-soft text-brand-ink/75">Memorial</span>
            <span class="rounded-full bg-white px-3 py-1 shadow-soft text-brand-ink/75">River Oaks</span>
          </div>
        </div>

        <div class="lg:col-span-4 flex lg:justify-end">
          <a href="/services" class="w-full lg:w-auto inline-flex items-center justify-center rounded-2xl bg-brand-moss px-5 py-3 text-white shadow-soft hover:opacity-90 transition">
            Explore Installation Services
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

   <!-- Social Proof #2 (mobile-friendly) -->
  <section id="social-proof-2" class="bg-white py-12 sm:py-16 desktop-xl:py-20 fhd:py-24">
    <div class="container mx-auto px-4">
      <h2 class="font-heading text-2xl sm:text-3xl mb-6 sm:mb-8 text-center">
        Trusted by Houston Homeowners & Designers
      </h2>

      <!-- Logo / Badge strip -->
        <div class="rounded-2xl bg-brand-sand/60 p-3 sm:p-4 shadow-soft">
        <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-x-10 sm:gap-y-6">
          <img src="/images/google review.png" alt="Google Reviews" class="h-6 sm:h-8 w-auto max-w-[140px] object-contain" loading="lazy" decoding="async">
          <img src="/images/Yelp_Logo.svg.png" alt="Yelp" class="h-6 sm:h-8 w-auto max-w-[140px] object-contain" loading="lazy" decoding="async">
          <img src="/images/Houzz logo.png" alt="Houzz" class="h-6 sm:h-8 w-auto max-w-[140px] object-contain" loading="lazy" decoding="async">
        </div>
      </div>

      <!-- Trust stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 desktop-xl:gap-8 fhd:gap-10 lg:gap-4 mt-6 sm:mt-8 md:max-w-3xl md:mx-auto lg:max-w-none">
        <div class="reveal rounded-2xl bg-white p-4 sm:p-6 shadow-soft text-center">
          <div class="text-2xl sm:text-3xl desktop-xl:text-4xl fhd:text-5xl font-semibold">4.9<span class="text-yellow-500 align-middle">★</span></div>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">Average rating (120+ reviews)</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-4 sm:p-6 shadow-soft text-center">
          <div class="text-2xl sm:text-3xl desktop-xl:text-4xl fhd:text-5xl font-semibold">300+</div>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">Houston homes installed</p>
        </div>
        <div class="rounded-2xl bg-white p-4 sm:p-6 shadow-soft text-center">
          <div class="text-2xl sm:text-3xl desktop-xl:text-4xl fhd:text-5xl font-semibold">14 Days</div>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">Typical start-to-finish timeline</p>
        </div>
        <div class="reveal rounded-2xl bg-white p-4 sm:p-6 shadow-soft text-center">
          <div class="text-2xl sm:text-3xl desktop-xl:text-4xl fhd:text-5xl font-semibold">98%</div>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">On-time project completion</p>
        </div>
      </div>

      <!-- Verified snippets -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 mt-6 sm:mt-8">
        <article class="rounded-2xl bg-white p-4 sm:p-6 shadow-soft">
          <div class="flex items-center gap-1.5 sm:gap-2 text-yellow-500 text-sm">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="mt-3 italic text-sm sm:text-base">"Their dust control was incredible. We lived in the home during install and it stayed clean."</p>
          <div class="mt-4 text-xs sm:text-sm text-brand-ink/70">— Michelle R., West University • Interior Designer</div>
        </article>

        <article class="rounded-2xl bg-white p-4 sm:p-6 shadow-soft">
          <div class="flex items-center gap-1.5 sm:gap-2 text-yellow-500 text-sm">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="mt-3 italic text-sm sm:text-base">"Wide planks look textbook perfect. The color match to our cabinets is spot on."</p>
          <div class="mt-4 text-xs sm:text-sm text-brand-ink/70">— Aaron K., The Woodlands • Homeowner</div>
        </article>

        <article class="rounded-2xl bg-white p-4 sm:p-6 shadow-soft">
          <div class="flex items-center gap-1.5 sm:gap-2 text-yellow-500 text-sm">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="mt-3 italic text-sm sm:text-base">"Started early, finished early, and passed moisture tests first time. Pro crew."</p>
          <div class="mt-4 text-xs sm:text-sm text-brand-ink/70">— Daniel M., River Oaks • Builder</div>
        </article>
      </div>

      <!-- Link to reviews -->
      <div class="mt-5 sm:mt-6 text-center">
        <a href="https://www.google.com/maps/place/Jamail+Hardwoods/@29.7384969,-95.4220915,17z/data=!4m8!3m7!1s0x8640c173d8f3159d:0x53225a833345782b!8m2!3d29.7384923!4d-95.4195166!9m1!1b1!16s%2Fg%2F11h8y31h3y?entry=ttu" target="_blank" rel="nofollow noopener noreferrer" class="inline-flex items-center gap-2 text-xs sm:text-sm text-brand-ink/70 hover:text-brand-ink">
          <img src="/images/Google_Favicon_2025.svg" alt="" class="h-4 w-4" loading="lazy" decoding="async">
          See 100+ verified Google reviews
        </a>
      </div>
    </div>
  </section>

  <!-- Bestselling Products with Category Tabs -->
  <section class="container mx-auto py-16 desktop-xl:py-20 fhd:py-24" id="catalog">
    <div class="flex flex-col sm:flex-row items-center justify-between mb-8 px-4">
      <h2 class="font-heading text-3xl">Bestselling Products</h2>
      <div class="flex items-center gap-2 mt-4 sm:mt-0">
        <button id="bestsellers-prev" aria-label="Previous" class="size-9 grid place-items-center rounded-full bg-brand-sand/70 shadow-soft hover:bg-white transition disabled:opacity-40 disabled:cursor-not-allowed">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor"><path stroke-width="2" d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button id="bestsellers-next" aria-label="Next" class="size-9 grid place-items-center rounded-full bg-brand-sand/70 shadow-soft hover:bg-white transition disabled:opacity-40 disabled:cursor-not-allowed">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor"><path stroke-width="2" d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="relative px-4">
      <div id="bestsellers-grid" class="grid grid-flow-col auto-cols-[calc(100%_-_0.75rem)] sm:auto-cols-[calc(50%_-_0.375rem)] md:auto-cols-[calc(50%_-_0.75rem)] lg:auto-cols-[calc(33.333%_-_1rem)] xl:auto-cols-[calc(25%_-_1.125rem)] desktop-xl:auto-cols-[calc(20%_-_1.125rem)] fhd:auto-cols-[calc(20%_-_1.25rem)] qhd:auto-cols-[calc(16.666%_-_1.25rem)] gap-3 md:gap-6 desktop-xl:gap-7 fhd:gap-8 overflow-x-auto snap-x snap-mandatory scroll-smooth" style="scrollbar-width: none; -ms-overflow-style: none;">
        <!-- Products will be injected here by script -->
      </div>
    </div>
  </section>

  <!-- UGC Social Proof (mobile-friendly) -->
  <section id="ugc-social-proof" class="bg-white py-12 sm:py-16 desktop-xl:py-20 fhd:py-24">
    <div class="container mx-auto px-4">
      <h2 class="font-heading text-2xl sm:text-3xl mb-6 sm:mb-8 text-center">
        Real Homes. Real Results.
      </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 desktop-xl:gap-8 fhd:gap-10">
        <!-- Card 1 -->
        <article class="reveal group relative overflow-hidden rounded-2xl bg-brand-sand shadow-soft">
          <a href="https://www.google.com/maps/place/Jamail+Hardwoods/@29.7384969,-95.4220915,17z/data=!4m8!3m7!1s0x8640c173d8f3159d:0x53225a833345782b!8m2!3d29.7384923!4d-95.4195166!9m1!1b1!16s%2Fg%2F11h8y31h3y?entry=ttu" target="_blank" rel="nofollow noopener noreferrer" class="block">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src="/images/Reviews/Hardwood Flooring Project Review.webp"
                alt="Client living room with wide-plank European White Oak"
                loading="lazy" class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
               decoding="async">
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-5 text-white">
              <div class="flex items-center gap-1.5 text-yellow-400 text-xs sm:text-sm" aria-label="5 star rating">
                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
              </div>
              <p class="mt-2 text-xs sm:text-sm italic leading-snug">
                "Jamail Hardwoods was amazing to work with! Their team was professional, friendly, and really knowledgeable about flooring options. The installation was quick, clean, and the quality of the hardwood is outstanding. My floors look beautiful. I highly recommend them!"
              </p>
              <p class="mt-2 text-[11px] sm:text-xs opacity-90">— Hassan Makiya</p>
            </div>
          </a>
        </article>

        <!-- Card 2 (video) -->
        <article class="reveal group relative overflow-hidden rounded-2xl bg-brand-sand shadow-soft">
            <div class="aspect-[4/3] overflow-hidden relative">
              <img
                src="/images/Reviews/Hardwood Flooring Project Review 2.webp"
                alt="Before/after walkthrough of European White Oak installation"
                loading="lazy" class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
               decoding="async">

            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-5 text-white">
              <div class="flex items-center gap-1.5 text-yellow-400 text-xs sm:text-sm" aria-label="5 star rating">
                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
              </div>
              <p class="mt-2 text-xs sm:text-sm italic leading-snug">
                "The entire experience was professional, 1st contact with Joey, outstanding customer service and he cute! The work crew showed up on time and completed the job better than I expected. Will definitely use them again for more floor work"
              </p>
              <p class="mt-2 text-[11px] sm:text-xs opacity-90">— Beverly Sagers</p>
            </div>
          </a>
        </article>

        <!-- Card 3 -->
        <article class="reveal group relative overflow-hidden rounded-2xl bg-brand-sand shadow-soft">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src="/images/Reviews/Hardwood Flooring Project Review 3.webp"
                alt="Modern kitchen with seamless European White Oak flooring"
                loading="lazy" class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
               decoding="async">
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-5 text-white">
              <div class="flex items-center gap-1.5 text-yellow-400 text-xs sm:text-sm" aria-label="5 star rating">
                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
              </div>
              <p class="mt-2 text-xs sm:text-sm italic leading-snug">
                "Joey and Victoria were awesome to deal with. Provided guidance through out my purchase and answered all of my questions. The flooring looks awesome and seems very durable. I have installed upper floor of my home so far and moving on to steps and main floor. Thank you so much Joey and Victoria, you were awesome."
              </p>
              <p class="mt-2 text-[11px] sm:text-xs opacity-90">— Simon Prazak</p>
            </div>
          </a>
        </article>
      </div>

      <!-- CTA -->
      <div class="mt-8 sm:mt-10 text-center">
        <a href="/products"
           class="inline-flex items-center justify-center rounded-2xl bg-brand-brass px-5 sm:px-6 py-3 text-white shadow-soft hover:opacity-90 transition">
          SHOP NOW
        </a>
      </div>
    </div>
  </section>

  <!-- Product Benefits (mobile-friendly) -->
  <section id="product-benefits" class="bg-white py-12 sm:py-16 desktop-xl:py-20 fhd:py-24">
    <div class="container mx-auto px-4">
      <h2 class="font-heading text-2xl sm:text-3xl mb-8 sm:mb-10 text-center">
        Why Homeowners Choose Jamail Hardwoods
      </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 desktop-xl:grid-cols-5 fhd:grid-cols-6 gap-4 sm:gap-6 desktop-xl:gap-7 fhd:gap-8">
        <!-- Card -->
        <article class="reveal rounded-2xl border border-black/5 bg-brand-sand/40 p-4 sm:p-5 shadow-soft">
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-moss shadow-soft">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M11 21c4.418 0 8-3.582 8-8V5a1 1 0 0 0-1-1h-8C5.582 4 2 7.582 2 12s3.582 9 9 9z"/>
              <path d="M8 14c2.5-1.5 5-3 8-6"/>
            </svg>
          </div>
          <h3 class="font-semibold text-base sm:text-lg">Low-VOC Finishes</h3>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">
            Cleaner indoor air for families, kids, and pets—without the fumes.
          </p>
        </article>

        <!-- Repeat cards -->
        <article class="reveal rounded-2xl border border-black/5 bg-brand-sand/40 p-4 sm:p-5 shadow-soft">
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-sky shadow-soft">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 3s7 7 7 12a7 7 0 0 1-14 0c0-5 7-12 7-12z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-base sm:text-lg">Moisture-Safe Installs</h3>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">
            Acclimation + moisture testing prevents cupping, gapping, and callbacks.
          </p>
        </article>

        <article class="reveal rounded-2xl border border-black/5 bg-brand-sand/40 p-4 sm:p-5 shadow-soft">
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-brass shadow-soft">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="12" r="9"/>
              <path d="M12 7v5l3 3"/>
            </svg>
          </div>
          <h3 class="font-semibold text-base sm:text-lg">7–14 Day Timeline</h3>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">
            Fast, predictable scheduling with on-time completion targets.
          </p>
        </article>

        <article class="reveal rounded-2xl border border-black/5 bg-brand-sand/40 p-4 sm:p-5 shadow-soft">
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-ink shadow-soft">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 3l2 4 4 2-4 2-2 4-2-4-4-2 4-2 2-4z"/>
              <path d="M19 14l1 2 2 1-2 1-1 2-1-2-2-1 2-1 1-2z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-base sm:text-lg">Designer-Grade Look</h3>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">
            Wide plank, consistent grain, and tones curated with Houston designers.
          </p>
        </article>

        <article class="reveal rounded-2xl border border-black/5 bg-brand-sand/40 p-4 sm:p-5 shadow-soft">
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-oak shadow-soft">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M14 7a4 4 0 1 0-5 5L3 18l3 3 6-6a4 4 0 0 0 2-8z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-base sm:text-lg">End-to-End Service</h3>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">
            From subfloor prep to final coat—one accountable pro team.
          </p>
        </article>

        <article class="reveal rounded-2xl border border-black/5 bg-brand-sand/40 p-4 sm:p-5 shadow-soft">
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-walnut shadow-soft">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M6.6 6.6L4 12h5l-2.4-5.4zM17.4 6.6L12 4l2 5 3.4-2.4zM18 12h5l-2.6-5.4L18 12zM6.6 17.4L12 20l-2-5-3.4 2.4zM12 9l-3 3 3 3 3-3-3-3z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-base sm:text-lg">Dust & Cleanup Included</h3>
          <p class="mt-1 text-xs sm:text-sm text-brand-ink/70">
            Containment + sweep on every job so you can live through the install.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Feature Section 1: Light & Modern -->
  <section class="container mx-auto px-4 py-12 sm:py-16 desktop-xl:py-20 fhd:py-24 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 desktop-xl:gap-12 fhd:gap-16 items-center">
