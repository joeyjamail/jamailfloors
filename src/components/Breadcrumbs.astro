---
export interface Crumb {
  label: string;
  href?: string;
}
export interface Props {
  items: Crumb[];
}
const { items } = Astro.props as Props;
---

<!-- Breadcrumbs Bar -->
<div class="bg-linear-to-b from-brand-sand/60 via-brand-ivory to-brand-ivory">
  <div class="container mx-auto px-4 sm:px-6 pt-10 pb-16">
    <nav aria-label="Breadcrumb" class="inline-flex items-center gap-2 bg-white/60 backdrop-blur-sm px-4 py-2.5 rounded-full shadow-soft border border-brand-sand/50">
      <!-- Home link -->
      <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-ink/70 hover:text-brand-brass transition-colors group">
        <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span class="hidden sm:inline">Home</span>
      </a>

      {items.map((item) => (
        <>
          <svg class="w-4 h-4 text-brand-brass" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          {item.href ? (
            <a href={item.href} class="text-sm font-medium text-brand-ink/70 hover:text-brand-brass transition-colors">{item.label}</a>
          ) : (
            <span class="text-sm font-semibold text-brand-brass">{item.label}</span>
          )}
        </>
      ))}
    </nav>
  </div>
</div>

